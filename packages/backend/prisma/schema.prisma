generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// ENUMS
// ============================================================

/// User roles — expanded to 11 fine-grained roles in Apr 2026 to match PPL's org structure.
/// ADMIN / STAFF / CLIENT are LEGACY values kept for backward compat during migration to
/// the UserRole junction table. New code should read from UserRole, not User.role directly.
/// The migration script in scripts/migrate-user-roles.ts backfills UserRole rows from
/// existing ADMIN/STAFF/CLIENT assignments with sensible defaults (STAFF→PERFORMANCE_COACH,
/// CLIENT→PARENT or ATHLETE based on Family membership).
enum Role {
  ADMIN // Legacy — migrate to UserRole(ADMIN)
  STAFF // Legacy — migrate to UserRole(PERFORMANCE_COACH) or COORDINATOR/MEDICAL
  CLIENT // Legacy — migrate to UserRole(PARENT) or UserRole(ATHLETE)

  // ========== New fine-grained roles ==========
  COORDINATOR // Everything at a specific location (Park-style)
  PERFORMANCE_COACH // Calendar, reports, athlete dashboard, notes/goals/programs at 1+ locations
  CONTENT_MARKETING_ADMIN // Global — oversees all social/marketing across all locations
  CONTENT_MARKETING // Location-scoped — typically layered on a Coach/Coordinator
  MEDICAL_ADMIN // Renewed Performance owner — sees weekly screening revenue per location
  MEDICAL // Screening staff — PTs and similar
  PARTNERSHIP_COACH // Scoped to 1+ partner schools (SchoolTeam), sees only their roster
  OUTSIDE_COACH // Linked to specific athletes via OutsideCoachLink — read-only + messaging
  PARENT // Manages 1+ athlete children via Family
  ATHLETE // Own dashboard, program, resources
}

enum SessionType {
  COLLEGE_PITCHING
  MS_HS_PITCHING
  YOUTH_PITCHING
  PRIVATE_LESSON
  CAGE_RENTAL
}

enum BookingStatus {
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum MembershipStatus {
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED
}

enum BillingDay {
  MONDAY
  THURSDAY
}

enum LocationRole {
  OWNER // Full revenue, settings, manage staff at this location
  PITCHING_COORDINATOR // Regular pitching coordinator — revenue splits, member data
  YOUTH_COORDINATOR // Youth pitching coordinator — revenue splits, member data
  COACH // See schedule and their own assigned clients only
  TRAINER // General trainer — similar to coach
}

// --- Family & Onboarding enums ---

enum AccountType {
  INDIVIDUAL // Single athlete, self-managed
  FAMILY // Parent managing 1+ athlete children
  PARTNER_SCHOOL // School team — lump-sum billing, no individual payments
}

enum AthleteRelationType {
  SELF // College athlete managing their own account
  CHILD // Parent's child
  TEAM_MEMBER // Part of a partner school team
}

enum OnboardingStatus {
  NEW // First time at PPL — owes $300 onboarding fee
  RETURNING // Has trained before — no fee
  PARTNER_SCHOOL // School athlete — no fee
}

enum OnboardingFeeStatus {
  REQUIRED // Fee owed, not yet paid
  PROCESSING // Stripe checkout in progress
  PAID // Fee collected
  WAIVED // Manually waived by admin
  NOT_APPLICABLE // Returning athlete or partner school — no fee
}

enum TrainingDeliveryPreference {
  IN_PERSON
  REMOTE
  HYBRID
}

enum SchoolInvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  VOID
}

enum CoachInviteStatus {
  NOT_SENT
  SENT
  ACCEPTED // Coach opened the link and submitted roster
  EXPIRED
}

enum ContractStatus {
  DRAFT
  SENT
  SIGNED
  EXPIRED
  VOIDED
}

enum SchoolCoachRole {
  HEAD_COACH
  ASSISTANT_COACH
  DIRECTOR
}

/// Distinguishes the three partner-school segments so we can route athletes to
/// the right dashboard variant (HighSchoolPartnerDashboard vs TravelTeamPartnerDashboard
/// vs CollegePartnerDashboard) and so Partnership Coaches see the right UX.
enum SchoolTeamType {
  HIGH_SCHOOL
  TRAVEL_TEAM
  COLLEGE
}

/// Self-declared coach type on an OutsideCoachLink — drives the "Message from
/// [Athlete]'s [CoachType]" subject prefix when an outside coach messages our
/// admin/coordinator, per Chad's spec.
enum OutsideCoachType {
  REC_BALL
  TRAVEL_BALL
  MIDDLE_SCHOOL
  HIGH_SCHOOL
  COLLEGE
  PITCHING_PRO
  PITCHING_COORDINATOR_PRO
  PLAYER_DEVELOPMENT
}

// --- CRM enums ---

/// Where the lead came from. Drives attribution reports + which nurture
/// sequence they land in (e.g. WEBSITE_FORM leads get the "we saw your
/// form" email; REFERRAL leads get a warmer opening). Values are append-only
/// — add new sources at the bottom, never rename existing ones.
enum LeadSource {
  WEBSITE_FORM // Landed on /register or the public contact form
  REFERRAL // Someone brought them in
  WALK_IN // Showed up at a PPL facility
  EVENT // Met us at an event / tournament
  PARTNER_SCHOOL // Partner-school coach referred their athlete
  COLD_OUTREACH // We reached out first
  PAID_AD // Clicked through from a paid ad (Meta, Google, etc.)
  SOCIAL // Organic social
  OTHER
}

/// Sales pipeline stages — ordered loosely by funnel progression, but the
/// CRM UI treats them as a kanban board so stage order is presentational.
enum PipelineStage {
  NEW // Just captured, haven't reached out
  CONTACTED // First outreach made
  QUALIFIED // Interested + a good fit
  ASSESSMENT_BOOKED // Booked a free assessment session
  ASSESSMENT_DONE // Assessment complete, we've pitched
  CLOSED_WON // Bought a membership
  CLOSED_LOST // Not a fit / no interest
  NURTURE // Long-term prospect, check back later
}

/// Activity types logged against a lead — the stream that makes up a
/// lead's history. STAGE_CHANGE + ASSIGNED are system-generated; everything
/// else is user-logged.
enum LeadActivityType {
  NOTE
  EMAIL_SENT
  EMAIL_OPENED
  CALL
  TEXT
  MEETING
  FORM_SUBMISSION
  STAGE_CHANGE // System — stage moved
  ASSIGNED // System — owner changed
}

