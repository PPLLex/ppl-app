  RETURNING // Has trained before — no fee
  PARTNER_SCHOOL // School athlete — no fee
}

enum OnboardingFeeStatus {
  REQUIRED // Fee owed, not yet paid
  PROCESSING // Stripe checkout in progress
  PAID // Fee collected
  WAIVED // Manually waived by admin
  NOT_APPLICABLE // Returning athlete or partner school — no fee
}

enum TrainingDeliveryPreference {
  IN_PERSON
  REMOTE
  HYBRID
}

enum SchoolInvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  VOID
}

enum CoachInviteStatus {
  NOT_SENT
  SENT
  ACCEPTED // Coach opened the link and submitted roster
  EXPIRED
}

enum ContractStatus {
  DRAFT
  SENT
  SIGNED
  EXPIRED
  VOIDED
}

enum SchoolCoachRole {
  HEAD_COACH
  ASSISTANT_COACH
  DIRECTOR
}

/// Distinguishes the three partner-school segments so we can route athletes to
/// the right dashboard variant (HighSchoolPartnerDashboard vs TravelTeamPartnerDashboard
/// vs CollegePartnerDashboard) and so Partnership Coaches see the right UX.
enum SchoolTeamType {
  HIGH_SCHOOL
  TRAVEL_TEAM
  COLLEGE
}

/// Self-declared coach type on an OutsideCoachLink — drives the "Message from
/// [Athlete]'s [CoachType]" subject prefix when an outside coach messages our
/// admin/coordinator, per Chad's spec.
enum OutsideCoachType {
  REC_BALL
  TRAVEL_BALL
  MIDDLE_SCHOOL
  HIGH_SCHOOL
  COLLEGE
  PITCHING_PRO
  PITCHING_COORDINATOR_PRO
  PLAYER_DEVELOPMENT
}

// --- CRM enums ---

/// Where the lead came from. Drives attribution reports + which nurture
/// sequence they land in (e.g. WEBSITE_FORM leads get the "we saw your
/// form" email; REFERRAL leads get a warmer opening). Values are append-only
/// — add new sources at the bottom, never rename existing ones.
enum LeadSource {
  WEBSITE_FORM // Landed on /register or the public contact form
  REFERRAL // Someone brought them in
  WALK_IN // Showed up at a PPL facility
  EVENT // Met us at an event / tournament
  PARTNER_SCHOOL // Partner-school coach referred their athlete
  COLD_OUTREACH // We reached out first
  PAID_AD // Clicked through from a paid ad (Meta, Google, etc.)
  SOCIAL // Organic social
  OTHER
}

/// Sales pipeline stages — ordered loosely by funnel progression, but the
/// CRM UI treats them as a kanban board so stage order is presentational.
enum PipelineStage {
  NEW // Just captured, haven't reached out
  CONTACTED // First outreach made
  QUALIFIED // Interested + a good fit
  ASSESSMENT_BOOKED // Booked a free assessment session
  ASSESSMENT_DONE // Assessment complete, we've pitched
  CLOSED_WON // Bought a membership
  CLOSED_LOST // Not a fit / no interest
  NURTURE // Long-term prospect, check back later
}

/// Activity types logged against a lead — the stream that makes up a
/// lead's history. STAGE_CHANGE + ASSIGNED are system-generated; everything
/// else is user-logged.
enum LeadActivityType {
  NOTE
  EMAIL_SENT
  EMAIL_OPENED
  CALL
  TEXT
  MEETING
  FORM_SUBMISSION
  STAGE_CHANGE // System — stage moved
  ASSIGNED // System — owner changed
}

// --- Medical screening enums ---

/// Status of a screening appointment. No-show and cancelled are preserved
/// (not deleted) so the Medical Admin revenue report can reason about
/// attendance rates and we can bill Renewed Performance for no-shows if
/// PPL's policy calls for it later.
enum ScreeningStatus {
  SCHEDULED
  CHECKED_IN
  COMPLETED
  NO_SHOW
  CANCELLED
}

// --- Marketing campaign enums ---

enum CampaignType {
  MARKETING // Bulk promotional blast
  ANNOUNCEMENT // One-off announcement (new location, schedule change, etc.)
  NURTURE // Drip-sequence step (automations ship later)
  TRANSACTIONAL // System event trigger (tracked for analytics parity)
}

enum CampaignStatus {
  DRAFT // Being edited
  SCHEDULED // Saved + scheduled for a future send
  SENDING // In-flight; fan-out in progress
  SENT // All recipients processed
  CANCELLED // Cancelled before send
  FAILED // Fan-out failed mid-run
}

/// Audience selectors — each campaign targets one of these segments.
/// audienceFilter JSON carries the parameters (e.g. locationId for
/// LOCATION_MEMBERS, ageGroup for AGE_GROUP).
enum CampaignAudience {
  ALL_MEMBERS // Every active member (not past-due, not cancelled)
  ALL_PARENTS // All PARENT users
  ALL_ATHLETES // All ATHLETE users
  ALL_LEADS // Every Lead in the CRM
  PAST_DUE_MEMBERS // Past-due / churned — win-back audience
  LOCATION_MEMBERS // Members at a specific location
  AGE_GROUP // Members in a specific age group
  CUSTOM_SEGMENT // Reserved for future segment builder
  IMPORTED_LIST // Uploaded CSV of email addresses
}

/// Per-recipient lifecycle. Maps roughly to Resend's webhook events.
enum RecipientStatus {
  PENDING // Queued, not yet handed to Resend
  SENT // Handed to Resend
  DELIVERED // Resend confirmed delivery
  OPENED // At least one open registered
  CLICKED // At least one click registered
  BOUNCED // Hard bounce
  FAILED // Resend-level failure
  UNSUBSCRIBED // Recipient unsubscribed after receiving
}

enum MetricType {
  FASTBALL_VELO
  CHANGEUP_VELO
  CURVEBALL_VELO
  SLIDER_VELO
  CUTTER_VELO
  SPIN_RATE
  COMMAND_SCORE
  MECHANICAL_SCORE
  BODY_WEIGHT
  CUSTOM
}

enum PaymentStatus {
  SUCCEEDED
  FAILED
  RETRYING
  REFUNDED
}

enum CardChangeRequestStatus {
  PENDING
  LINK_SENT
  COMPLETED
  DENIED
}

enum NotificationType {
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  BOOKING_REMINDER
  PAYMENT_SUCCEEDED
  PAYMENT_FAILED
  CREDITS_REVOKED
  CREDITS_RESTORED
  NEW_MESSAGE
  SCHEDULE_CHANGED
  MEMBERSHIP_STATUS_CHANGE
}

enum NotificationChannel {
  EMAIL
  SMS
  PUSH
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

// ============================================================
// ORGANIZATIONS — top-level tenant layer
// ============================================================
// Every business entity lives under an Organization. PPL is the first org,
// HPL and Renewed Performance come online as separate brands. Apps share
// the same backend + DB; each app reads org context from its domain or the
// user's memberships and filters all queries by organizationId. See
// ARCHITECTURE.md at the repo root for the rules and phases.
//
// The four seeded orgs use their slugs as primary keys (not UUIDs) so code
// and SQL can reference them readably:
//   - "ppl"                  Pitching Performance Lab
//   - "hpl"                  Hitting Performance Lab
//   - "hpl-youth"            HPL Youth (sub-brand, may consolidate into hpl)
//   - "renewed-performance"  Renewed Performance (screenings, no client memberships)

model Organization {
  id        String  @id // slug used as ID: "ppl", "hpl", ...
  name      String // "Pitching Performance Lab"
  shortName String // "PPL"
  tagline   String?

  // Branding
  logoUrl      String?
  logoData     String? // base64 fallback
  primaryColor String  @default("#5E9E50")
  accentColor  String  @default("#95C83C")

  // Domain routing — used by the frontend OrgContext to pick the active org
  primaryDomain     String?  @unique // e.g., "app.pitchingperformancelab.com"
  additionalDomains String[] @default([])

  // Stripe — charges for this org's memberships land on this account.
  // Joint memberships are charged once on the originating app's Stripe account
  // and reconciled via the revenue ledger (see services/revenueLedger.ts).
  stripeAccountId String?

  // Defaults used when creating sessions/rooms in this org
  defaultCapacity         Int @default(8)
  sessionDurationMinutes  Int @default(60)
  registrationCutoffHours Int @default(1)
  cancellationCutoffHours Int @default(6)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("organizations")
}

// ============================================================
// LOCATIONS
// ============================================================

model Location {
  id             String   @id @default(uuid())
  name           String
  address        String?
  phone          String?
  timezone       String   @default("America/Chicago")
  operatingHours Json? // { monday: { open: "06:00", close: "21:00" }, ... }
  closedDay      String? // e.g., "sunday"
  kioskPin       String? // 4-6 digit PIN for self-service kiosk check-in
  // See ARCHITECTURE.md — every org-tagged table defaults to "ppl" so existing
  // rows land on PPL when the column is added, and Organization FK is added
  // in a follow-up migration once the 4 orgs are seeded.
  organizationId String   @default("ppl")
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  users                User[]
  staffLocations       StaffLocation[]
  rooms                Room[]
  sessions             Session[]
  clientMemberships    ClientMembership[]
  conversations        Conversation[]
  auditLogs            AuditLog[]
  families             Family[]
  schoolTeams          SchoolTeam[]
  scheduleTemplates    ScheduleTemplate[]
  sessionTypeConfigs   SessionTypeConfig[]
  attendanceViolations AttendanceViolation[]
  // UserRole assignments scoped to this location (COORDINATOR,
  // PERFORMANCE_COACH, CONTENT_MARKETING, MEDICAL, MEDICAL_ADMIN roles).
  userRoles            UserRole[]
  // Leads interested in this location.
  leads                Lead[]
  // Medical screenings held at this location — drives the weekly revenue
  // report grouped by location for the Medical Admin.
  medicalScreenings    MedicalScreening[]
  // Consultation slots that physically take place at this location (vs phone)
  consultationSlots    ConsultationSlot[]

  @@index([organizationId])
  @@map("locations")
}

// ============================================================
// USERS & AUTH
// ============================================================

model User {
  id               String  @id @default(uuid())
  email            String  @unique
  passwordHash     String? // Optional — null for OAuth-only accounts
  fullName         String
  phone            String?
  role             Role    @default(CLIENT)
  homeLocationId   String?
  isActive         Boolean @default(true)
  stripeCustomerId String? @unique

  // Churn risk score 0-100 for active members — computed nightly via
  // services/churnRisk.ts. Higher = more likely to drop off. Drives the
  // "At-Risk Members" admin dashboard.
  churnRiskScore     Int       @default(0)
  churnScoreUpdatedAt DateTime?

  // Family & account type fields
  accountType  AccountType @default(INDIVIDUAL)
  isParent     Boolean     @default(false)
  parentUserId String? // Self-ref: college athletes who opt out of adding a parent

  // OAuth fields
  authProvider String? // "email", "google", "apple" — primary auth method
  googleId     String? @unique
  appleId      String? @unique
  avatarUrl    String?

  // Magic link fields
  magicLinkToken  String?   @unique
  magicLinkExpiry DateTime?

  // Referral program (#134) — generated lazily on first need
  referralCode    String? @unique

  // ============================================================
  // SECURITY (#141, #142, account lockout)
  // ============================================================
  // Two-factor auth (TOTP via otplib). Secret is base32, stored at-rest.
  // enabledAt set the moment the user verifies their first TOTP code; until
  // then `secret` is a "pending" enrollment value that login does NOT enforce.
  // recoveryCodes is an array of bcrypt-hashed one-time codes (10 issued
  // at enrollment, regenerable from the security page). pendingChallenge
  // holds a short-lived random token issued by /auth/login when 2FA is
  // required — the client trades it + the TOTP code for a real JWT.
  twoFactorSecret             String?
  twoFactorEnabledAt          DateTime?
  twoFactorRecoveryCodes      String[]  @default([])
  twoFactorPendingChallenge   String?   @unique
  twoFactorChallengeExpiresAt DateTime?

  // Email verification (#142). emailVerifiedAt is the moment the user
  // clicked the link from /auth/verify-email; null = unverified. New
  // self-registered accounts start unverified; admin-invited and OAuth
  // accounts are pre-verified. emailVerificationToken is a one-time
  // random token; expires 24h after issue.
  emailVerifiedAt              DateTime?
  emailVerificationToken       String?   @unique
  emailVerificationTokenExpiry DateTime?

  // Account lockout (PREMIUM_AUDIT S2). 5 fails in 15 min → lock 15 min.
  // failedLoginCount resets on successful login or after the 15-min
  // window elapses. lockedUntil is checked at the top of the login
  // handler — if non-null and in the future, login is rejected.
  failedLoginCount   Int       @default(0)
  failedLoginResetAt DateTime?
  lockedUntil        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  homeLocation       Location?           @relation(fields: [homeLocationId], references: [id])
  parentUser         User?               @relation("ParentChild", fields: [parentUserId], references: [id])
  childUsers         User[]              @relation("ParentChild")
  clientProfile      ClientProfile?
  family             Family?             @relation("FamilyParent")
  athleteProfile     AthleteProfile?     @relation("AthleteUser")
  staffLocations     StaffLocation[]
  coachedSessions    Session[]           @relation("SessionCoach")
  bookings           Booking[]
  clientMemberships  ClientMembership[]
  weeklyCredits      WeeklyCredit[]
  payments           Payment[]
  cardChangeRequests CardChangeRequest[] @relation("ClientCardRequests")
  adminCardRequests  CardChangeRequest[] @relation("AdminCardRequests")
  sentMessages       Message[]
  notifications      Notification[]
  pushTokens         PushToken[]
  auditLogs          AuditLog[]

  // Coach Notes relations
  athleteNotes     CoachNote[]       @relation("AthleteNotes")
  coachNotes       CoachNote[]       @relation("CoachNotes")
  athleteDigests   NoteDigest[]      @relation("AthleteDigests")
  digestRecipients DigestRecipient[] @relation("DigestRecipients")

  // Goals & Forms relations
  athleteGoals  Goal[]         @relation("AthleteGoals")
  coachGoals    Goal[]         @relation("CoachGoals")
  createdForms  FormTemplate[] @relation("CreatedForms")
  formResponses FormResponse[] @relation("FormResponses")

  // Programming relations
  coachPrograms   Program[] @relation("CoachPrograms")
  athletePrograms Program[] @relation("AthletePrograms")

  // Metrics relations
  athleteMetrics    AthleteMetric[] @relation("AthleteMetrics")
  staffCoachMetrics AthleteMetric[] @relation("StaffCoachMetrics")

  // Schedule template & violation relations
  scheduleTemplates    ScheduleTemplate[]    @relation("TemplateCoach")
  attendanceViolations AttendanceViolation[] @relation("ViolationClient")
  assessedViolations   AttendanceViolation[] @relation("ViolationAssessor")

  // Liability waiver signatures this user signed (as the signing adult — parent or self)
  signedWaivers LiabilityWaiverSignature[]

  // Role assignments — a user can hold multiple roles simultaneously (e.g. a
  // Performance Coach who also does Content & Marketing). Supersedes the
  // single `role` column above during the April 2026 role-model migration.
  // See schema.prisma Role enum comment for the full list.
  userRoles UserRole[]

  // CRM relations — staff-side (ownedLeads, loggedLeadActivities) + the
  // reverse link from the Lead that converted into this user (nullable
  // because direct signups don't have a preceding Lead row).
  ownedLeads           Lead[]         @relation("LeadOwner")
  convertedFromLead    Lead?          @relation("LeadConverted")
  loggedLeadActivities LeadActivity[] @relation("LeadActivityAuthor")

  // Medical screenings this user is the PROVIDER for (MEDICAL /
  // MEDICAL_ADMIN roles). Null providerUserId on a screening means
  // it's been scheduled but not yet assigned to a PT.
  providedScreenings MedicalScreening[] @relation("ScreeningProvider")

  // Email campaigns this user created + campaigns this user received.
  createdCampaigns      EmailCampaign[]     @relation("CampaignCreator")
  receivedCampaignSends CampaignRecipient[] @relation("CampaignUserRecipient")

  // Tagging system (Phase 1A)
  createdTags    Tag[]           @relation("TagCreatedBy")
  tagAssignments TagAssignment[] @relation("UserTags")
  assignedTags   TagAssignment[] @relation("TagAssignedBy")

  // Custom field values (Phase 1B)
  customFieldValues CustomFieldValue[] @relation("UserCustomFields")

  // Workflows authored by this user (Phase 1C)
  createdWorkflows Workflow[] @relation("WorkflowCreatedBy")
  createdWebhooks  Webhook[]  @relation("WebhookCreatedBy")
  hostedConsultations ConsultationSlot[] @relation("ConsultationHost")

  // Marketing forms (#133)
  createdMarketingForms     MarketingForm[]           @relation("MarketingFormsCreated")
  marketingFormSubmissions  MarketingFormSubmission[] @relation("MarketingFormSubmissionUser")

  // Referral program (#134)
  referralsMade     Referral[] @relation("ReferralsMade")
  referralReceived  Referral?  @relation("ReferralReceived")

  @@index([homeLocationId])
  @@index([role])
  @@index([email])
  @@map("users")
}

/// Multi-role assignment — a user can have 1+ UserRole rows. This supersedes
/// the single `User.role` column, which is kept for backward compat during
/// the transition.
///
/// Scoping semantics (nullable per row depending on role):
///   - Global roles (ADMIN, CONTENT_MARKETING_ADMIN, MEDICAL_ADMIN, PARENT,
///     ATHLETE): locationId=null, schoolTeamId=null
///   - Location-scoped roles (COORDINATOR, PERFORMANCE_COACH,
///     CONTENT_MARKETING, MEDICAL): locationId=X, schoolTeamId=null
///   - Partnership Coach: locationId=null, schoolTeamId=X (1 row per school)
///   - Outside Coach: represented elsewhere via OutsideCoachLink rows
///
/// A user who's a Performance Coach at TWO locations gets TWO rows (one per
/// locationId). A user who's both a Performance Coach and a Content &
/// Marketing team member at Lexington gets TWO rows (different role, same
/// locationId). The UNIQUE constraint prevents accidental duplicates of the
/// same (user, role, location, school) tuple.
model UserRole {
  id           String   @id @default(uuid())
  userId       String
  role         Role
  // Null for global roles (ADMIN, CONTENT_MARKETING_ADMIN, MEDICAL_ADMIN,
  // PARENT, ATHLETE) and for Partnership Coach (scoped by schoolTeamId).
  locationId   String?
  // Set ONLY when role=PARTNERSHIP_COACH — one row per partner school this
  // coach is responsible for.
  schoolTeamId String?
  createdAt    DateTime @default(now())

  // Relations
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  location   Location?   @relation(fields: [locationId], references: [id])
  schoolTeam SchoolTeam? @relation(fields: [schoolTeamId], references: [id])

  @@unique([userId, role, locationId, schoolTeamId])
  @@index([userId])
  @@index([role, locationId])
  @@index([schoolTeamId])
  @@map("user_roles")
}

model ClientProfile {
  id                    String                      @id @default(uuid())
  userId                String                      @unique
  ageGroup              String? // "youth", "ms_hs", "college"
  dateOfBirth           DateTime?
  emergencyContactName  String?
  emergencyContactPhone String?
  trainingGoals         String?
  trainingPreference    TrainingDeliveryPreference?
  notes                 String?
  waiverSignedAt        DateTime?
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("client_profiles")
}

model StaffLocation {
  id         String         @id @default(uuid())
  staffId    String
  locationId String
  roles      LocationRole[] @default([COACH])
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  // Relations
  staff    User     @relation(fields: [staffId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([staffId, locationId])
  @@index([locationId])
  @@map("staff_locations")
}

model StaffInvite {
  id        String    @id @default(uuid())
  email     String
  fullName  String
  phone     String?
  token     String    @unique @default(uuid())
  role      Role      @default(STAFF)
  locations Json // [{locationId, roles: ['PITCHING_COORDINATOR', ...]}]
  expiresAt DateTime
  usedAt    DateTime?
  invitedBy String?
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([email])
  @@map("staff_invites")
}

// ============================================================
// ROOMS & SCHEDULING
// ============================================================

model Room {
  id         String   @id @default(uuid())
  locationId String
  name       String
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  location          Location           @relation(fields: [locationId], references: [id], onDelete: Cascade)
  sessions          Session[]
  scheduleTemplates ScheduleTemplate[]

  @@index([locationId])
  @@map("rooms")
}

model Session {
  id                      String      @id @default(uuid())
  organizationId          String      @default("ppl")
  locationId              String
  roomId                  String?
  coachId                 String?
  title                   String
  sessionType             SessionType
  startTime               DateTime
  endTime                 DateTime
  maxCapacity             Int         @default(8)
  currentEnrolled         Int         @default(0)
  recurringRule           String? // iCal RRULE format
  recurringGroupId        String? // links recurring instances
  registrationCutoffHours Int         @default(2)
  cancellationCutoffHours Int         @default(4)
  isActive                Boolean     @default(true)
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  // Relations
  location             Location              @relation(fields: [locationId], references: [id])
  room                 Room?                 @relation(fields: [roomId], references: [id])
  coach                User?                 @relation("SessionCoach", fields: [coachId], references: [id])
  bookings             Booking[]
  attendanceViolations AttendanceViolation[]

  @@index([organizationId, startTime])
  @@index([locationId, startTime])
  @@index([coachId])
  @@index([sessionType])
  @@index([recurringGroupId])
  @@map("sessions")
}

model Booking {
  id                 String        @id @default(uuid())
  clientId           String
  sessionId          String
  status             BookingStatus @default(CONFIRMED)
  creditsUsed        Int           @default(1)
  cancelledAt        DateTime?
  cancellationReason String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  // Relations
  client             User                @relation(fields: [clientId], references: [id])
  session            Session             @relation(fields: [sessionId], references: [id])
  creditTransactions CreditTransaction[]
  coachNotes         CoachNote[]

  @@unique([clientId, sessionId])
  @@index([clientId, status])
  @@index([sessionId])
  @@map("bookings")
}

// ============================================================
// ATTENDANCE VIOLATIONS & FINES
// ============================================================

enum ViolationType {
  NO_SIGNUP // Showed up without booking ($20 fine)
  WRONG_TIME // Showed up at incorrect session time ($10 fine)
}

enum ViolationStatus {
  PENDING // Fine assessed, not yet paid
  PAID // Fine collected via Stripe
  WAIVED // Admin waived the fine
}

model AttendanceViolation {
  id           String          @id @default(uuid())
  clientId     String
  sessionId    String? // Which session they walked into (null if no specific session)
  locationId   String
  type         ViolationType
  amountCents  Int // 2000 = $20, 1000 = $10
  status       ViolationStatus @default(PENDING)
  notes        String? // Coach/admin notes on what happened
  assessedById String // Staff/admin who logged it
  paidAt       DateTime?
  waivedAt     DateTime?
  waivedById   String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  client     User     @relation("ViolationClient", fields: [clientId], references: [id])
  session    Session? @relation(fields: [sessionId], references: [id])
  location   Location @relation(fields: [locationId], references: [id])
  assessedBy User     @relation("ViolationAssessor", fields: [assessedById], references: [id])

  @@index([clientId])
  @@index([sessionId])
  @@index([status])
  @@map("attendance_violations")
}

/// Admin-defined weekly schedule template.
/// Each entry is "every Monday at 3pm in Room A, College Pitching".
/// A cron job uses these to auto-generate Session rows 2 weeks ahead.
model ScheduleTemplate {
  id                      String      @id @default(uuid())
  organizationId          String      @default("ppl")
  locationId              String
  roomId                  String?
  coachId                 String?
  title                   String
  sessionType             SessionType
  dayOfWeek               Int // 0=Sunday … 6=Saturday
  startHour               Int // 0-23
  startMinute             Int         @default(0)
  durationMinutes         Int         @default(60)
  maxCapacity             Int         @default(8)
  registrationCutoffHours Int         @default(2)
  cancellationCutoffHours Int         @default(4)
  isActive                Boolean     @default(true)
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  location Location @relation(fields: [locationId], references: [id])
  room     Room?    @relation(fields: [roomId], references: [id])
  coach    User?    @relation("TemplateCoach", fields: [coachId], references: [id])

  @@index([organizationId])
  @@index([locationId, dayOfWeek])
  @@map("schedule_templates")
}

// ============================================================
// SESSION TYPE CONFIGURATION  (per-location defaults per type)
// ============================================================

model SessionTypeConfig {
  id                      String      @id @default(uuid())
  organizationId          String      @default("ppl")
  locationId              String
  sessionType             SessionType
  label                   String // Display name, e.g. "College Pitching"
  maxCapacity             Int         @default(8)
  durationMinutes         Int         @default(60)
  registrationCutoffHours Int         @default(2)
  cancellationCutoffHours Int         @default(4)
  color                   String? // Hex color for calendar display, e.g. "#10B981"
  isActive                Boolean     @default(true)
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  location Location @relation(fields: [locationId], references: [id])

  @@unique([locationId, sessionType])
  @@index([organizationId])
  @@map("session_type_configs")
}

// ============================================================
// MEMBERSHIPS & BILLING
// ============================================================

model MembershipPlan {
  id               String   @id @default(uuid())
  organizationId   String   @default("ppl")
  name             String // "Unlimited College Pitching", "Youth 1x/Week", etc.
  slug             String   @unique
  ageGroup         String // "college", "ms_hs", "youth"
  sessionsPerWeek  Int? // null = unlimited
  priceCents       Int // e.g., 8500 = $85.00
  billingCycle     String   @default("weekly")
  description      String?
  isActive         Boolean  @default(true)
  // Discipline / bundling.
  //   includesHitting   — this plan covers hitting training in addition to pitching.
  //                       On PPL app, hitting is only available as an add-on; the
  //                       registration UI offers a "+ Add Hitting" toggle that
  //                       swaps the user to the paired combo plan.
  //   pairedWithPlanId  — points to the sibling plan in the pitching/combo pair.
  //                       A pitching-only plan points to its combo; the combo
  //                       points back to the pitching-only plan. Always bidirectional
  //                       so the UI can navigate either direction.
  //   revenueSplits     — how the weekly (or monthly) priceCents is divided
  //                       BETWEEN BUSINESSES. JSON object keyed by org slug, values
  //                       in cents. MUST sum to priceCents. Example:
  //                         { "ppl": 5000, "hpl": 4000 }  for a $90/wk Youth combo.
  //                       Pitching-only plans are 100% PPL → { "ppl": <priceCents> }.
  //                       Used by the weekly inter-business settlement report.
  includesHitting  Boolean  @default(false)
  pairedWithPlanId String?
  revenueSplits    Json     @default("{}")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  clientMemberships ClientMembership[]

  @@index([organizationId])
  @@map("membership_plans")
}

model ClientMembership {
  id                   String           @id @default(uuid())
  clientId             String
  planId               String
  locationId           String
  athleteId            String? // Links to AthleteProfile — null for legacy memberships
  status               MembershipStatus @default(ACTIVE)
  stripeSubscriptionId String?          @unique
  stripePriceId        String?
  billingDay           BillingDay
  billingAnchorDate    DateTime
  startedAt            DateTime         @default(now())
  cancelledAt          DateTime?
  cancelRequestedAt    DateTime?
  // Pause/resume (#137) — when status=PAUSED, pauseUntil is the auto-resume date.
  pausedAt             DateTime?
  pauseUntil           DateTime?
  pauseReason          String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  // Relations
  client        User            @relation(fields: [clientId], references: [id])
  plan          MembershipPlan  @relation(fields: [planId], references: [id])
  location      Location        @relation(fields: [locationId], references: [id])
  athlete       AthleteProfile? @relation(fields: [athleteId], references: [id])
  weeklyCredits WeeklyCredit[]
  payments      Payment[]

  @@index([clientId, status])
  @@index([status])
  @@index([billingDay])
  @@map("client_memberships")
}

model WeeklyCredit {
  id             String   @id @default(uuid())
  // org is direct here because joint memberships split credits into pools
  // tagged per-org (1 PPL credit + 1 HPL credit, never cross-spendable).
  // Filtering credits by org is a hot path.
  organizationId String   @default("ppl")
  clientId       String
  membershipId   String
  creditsTotal   Int
  creditsUsed    Int      @default(0)
  weekStartDate  DateTime
  weekEndDate    DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  client     User             @relation(fields: [clientId], references: [id])
  membership ClientMembership @relation(fields: [membershipId], references: [id])

  @@unique([clientId, membershipId, weekStartDate])
  @@index([clientId, weekStartDate])
  @@index([organizationId, weekStartDate])
  @@map("weekly_credits")
}

model CreditTransaction {
  id              String   @id @default(uuid())
  clientId        String
  transactionType String // "usage", "refund", "revoke", "restore"
  amount          Int // positive = added, negative = used/revoked
  bookingId       String?
  paymentId       String?
  notes           String?
  createdAt       DateTime @default(now())

  // Relations
  booking Booking? @relation(fields: [bookingId], references: [id])

  @@index([clientId, createdAt])
  @@map("credit_transactions")
}

// ============================================================
// PAYMENTS
// ============================================================

model Payment {
  id                    String        @id @default(uuid())
  clientId              String
  membershipId          String?
  stripePaymentIntentId String?       @unique
  stripeInvoiceId       String?       @unique
  amountCents           Int
  status                PaymentStatus
  failureReason         String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  // Relations
  client     User              @relation(fields: [clientId], references: [id])
  membership ClientMembership? @relation(fields: [membershipId], references: [id])

  @@index([clientId, createdAt])
  @@index([status])
  @@map("payments")
}

model CardChangeRequest {
  id               String                  @id @default(uuid())
  clientId         String
  adminId          String?
  status           CardChangeRequestStatus @default(PENDING)
  secureLinkToken  String?                 @unique
  secureLinkExpiry DateTime?
  newCardVerified  Boolean                 @default(false)
  notes            String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  // Relations
  client User  @relation("ClientCardRequests", fields: [clientId], references: [id])
  admin  User? @relation("AdminCardRequests", fields: [adminId], references: [id])

  @@index([clientId])
  @@index([status])
  @@map("card_change_requests")
}

// ============================================================
// MESSAGING
// ============================================================

model Conversation {
  id           String   @id @default(uuid())
  locationId   String?
  participants Json // array of user IDs
  type         String // "client_coach", "client_admin"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  location Location? @relation(fields: [locationId], references: [id])
  messages Message[]

  @@map("conversations")
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  readBy         Json     @default("[]") // array of user IDs who have read
  createdAt      DateTime @default(now())

  // Relations
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id])

  @@index([conversationId, createdAt])
  @@map("messages")
}

// ============================================================
// NOTIFICATIONS
// ============================================================

model Notification {
  id        String              @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  channel   NotificationChannel
  status    NotificationStatus  @default(PENDING)
  metadata  Json? // extra data (booking ID, payment amount, etc.)
  // Optional click-through link for the in-app bell — when set, clicking
  // a notification both marks it read and navigates here.
  link      String?
  // In-app read tracking — separate from delivery status above. Null
  // means unread; setting drives the bell unread count.
  readAt    DateTime?
  sentAt    DateTime?
  createdAt DateTime            @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([userId, readAt])
  @@index([status])
  @@map("notifications")
}

// ============================================================
// PUSH NOTIFICATION TOKENS
// ============================================================

model PushToken {
  id         String   @id @default(uuid())
  userId     String
  token      String   @unique // FCM device token
  deviceInfo String? // "Chrome on Windows", "Safari on iPhone", etc.
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_tokens")
}

// ============================================================
// COACH SESSION NOTES
// ============================================================

enum TrainingCategory {
  PITCHING_MECHANICS
  VELOCITY_TRAINING
  ARM_CARE
  BULLPEN_SESSION
  LIVE_AT_BATS
  VIDEO_REVIEW
  STRENGTH_CONDITIONING
  MENTAL_PERFORMANCE
  GENERAL
  OTHER
}

model CoachNote {
  id               String           @id @default(uuid())
  athleteId        String
  coachId          String? // PPL staff coach (null if school coach)
  schoolCoachId    String? // Partner school coach (null if PPL staff)
  trainingCategory TrainingCategory
  rawContent       String // original note from coach
  cleanedContent   String? // AI-cleaned version (grammar, profanity filtered)
  sessionDate      DateTime         @default(now())
  bookingId        String? // optional link to a specific booking
  isVisible        Boolean          @default(true) // can be hidden if needed
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  // Relations
  athlete     User         @relation("AthleteNotes", fields: [athleteId], references: [id])
  coach       User?        @relation("CoachNotes", fields: [coachId], references: [id])
  schoolCoach SchoolCoach? @relation("SchoolCoachNotes", fields: [schoolCoachId], references: [id])
  booking     Booking?     @relation(fields: [bookingId], references: [id])

  @@index([athleteId, createdAt])
  @@index([coachId, createdAt])
  @@index([schoolCoachId, createdAt])
  @@index([athleteId, trainingCategory])
  @@map("coach_notes")
}

// Weekly email digest tracking
model NoteDigest {
  id          String    @id @default(uuid())
  athleteId   String
  weekStart   DateTime
  weekEnd     DateTime
  emailSentAt DateTime?
  recipients  Json // array of email addresses that received this digest
  noteIds     Json // array of CoachNote IDs included
  htmlContent String? // rendered email content for audit
  createdAt   DateTime  @default(now())

  // Relations
  athlete User @relation("AthleteDigests", fields: [athleteId], references: [id])

  @@unique([athleteId, weekStart])
  @@index([weekStart])
  @@map("note_digests")
}

// Additional email recipients per athlete (parent emails, on-field coaches, etc.)
model DigestRecipient {
  id        String   @id @default(uuid())
  athleteId String
  email     String
  name      String?
  relation  String? // "parent", "coach", "guardian", etc.
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  athlete User @relation("DigestRecipients", fields: [athleteId], references: [id])

  @@unique([athleteId, email])
  @@map("digest_recipients")
}

// ============================================================
// GOALS & GAMIFICATION
// ============================================================

enum GoalType {
  SHORT_TERM // weeks
  LONG_TERM // months/season
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  ABANDONED
}

model Goal {
  id          String     @id @default(uuid())
  athleteId   String
  coachId     String? // coach who set it, or null if self-set
  type        GoalType
  title       String
  description String?
  targetDate  DateTime?
  status      GoalStatus @default(ACTIVE)
  progress    Int        @default(0) // 0-100 percentage
  completedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Relations
  athlete User  @relation("AthleteGoals", fields: [athleteId], references: [id])
  coach   User? @relation("CoachGoals", fields: [coachId], references: [id])

  @@index([athleteId, status])
  @@index([athleteId, type])
  @@map("goals")
}

// ============================================================
// CUSTOM FORMS (onboarding, questionnaires, intake, etc.)
// ============================================================

model FormTemplate {
  id           String   @id @default(uuid())
  createdById  String
  title        String
  description  String?
  fields       Json // array of field definitions: [{name, type, label, required, options}]
  isOnboarding Boolean  @default(false) // if true, new athletes must fill it out
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  createdBy User           @relation("CreatedForms", fields: [createdById], references: [id])
  responses FormResponse[]

  @@map("form_templates")
}

model FormResponse {
  id        String   @id @default(uuid())
  formId    String
  athleteId String
  answers   Json // { fieldName: answer, ... }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  form    FormTemplate @relation(fields: [formId], references: [id])
  athlete User         @relation("FormResponses", fields: [athleteId], references: [id])

  @@unique([formId, athleteId]) // one response per athlete per form (can update)
  @@index([athleteId])
  @@map("form_responses")
}

// ============================================================
// MARKETING FORMS — public-facing forms (lead intake, surveys,
// post-session feedback). Distinct from FormTemplate, which is
// internal-only athlete questionnaires.
//
// Each form has a public slug (formspublic.pitchingperformancelab.com/f/<slug>),
// can collect anonymous OR identified responses, and optionally
// scheduled delivery — e.g. a feedback form auto-emailed 24h after
// any completed booking. Schedule semantics handled by workflow engine.
// ============================================================

enum MarketingFormTrigger {
  MANUAL                 // sent by admin via "send form" button
  POST_BOOKING_COMPLETE  // after a booking ends successfully (delayHours)
  POST_FIRST_SESSION     // after the athlete's first-ever session
  POST_MEMBERSHIP_START  // X hours after subscription activated
  POST_LEAD_CREATED      // X hours after lead row created
}

model MarketingForm {
  id              String   @id @default(uuid())
  organizationId  String   @default("ppl")
  slug            String // unique within org — used for public URL
  name            String
  description     String?
  fields          Json // [{key, label, type, required, options?, placeholder?, helpText?}]
  submitMessage   String?
  redirectUrl     String?
  isActive        Boolean  @default(true)
  isPublic        Boolean  @default(true) // false → only authenticated users can submit
  collectEmail    Boolean  @default(true)
  collectName     Boolean  @default(true)
  // Optional scheduled delivery config — when set, this form is
  // automatically emailed to the right audience on the trigger.
  trigger         MarketingFormTrigger @default(MANUAL)
  triggerDelayHours Int    @default(24)
  // If set, automatically converts submission into a Lead row
  autoCreateLead  Boolean  @default(false)
  // If set, automatically tags the submitter with these tag IDs
  autoTagIds      String[]
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  createdBy    User?                       @relation("MarketingFormsCreated", fields: [createdById], references: [id])
  submissions  MarketingFormSubmission[]

  @@unique([organizationId, slug])
  @@index([trigger, isActive])
  @@map("marketing_forms")
}

model MarketingFormSubmission {
  id              String   @id @default(uuid())
  formId          String
  // What did they submit? Full key→value map of answers.
  payload         Json
  // Identity (any of these may be null for fully-anonymous submissions)
  submitterEmail  String?
  submitterName   String?
  submitterPhone  String?
  // Linked entities — set when we can match the email to an existing
  // Lead/User, OR when autoCreateLead spawns a new lead row.
  leadId          String?
  userId          String?
  ipAddress       String?
  userAgent       String?
  source          String? // "public", "scheduled-email", "admin-send", etc.
  submittedAt     DateTime @default(now())

  form MarketingForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  lead Lead?         @relation("MarketingFormSubmissionLead", fields: [leadId], references: [id])
  user User?         @relation("MarketingFormSubmissionUser", fields: [userId], references: [id])

  @@index([formId, submittedAt])
  @@index([submitterEmail])
  @@index([leadId])
  @@index([userId])
  @@map("marketing_form_submissions")
}

// ============================================================
// REFERRAL PROGRAM (#134) — refer a friend, both get a free week.
//
// Each user gets a unique referralCode (auto-generated). When someone
// registers using ?ref=CODE, a Referral row is created with status
// PENDING. When the referee makes their first paid purchase (handled
// in the Stripe payment.succeeded webhook), the Referral is marked
// REWARDED and 7 booking credits are issued to BOTH users.
//
// Referrals expire 90 days after registration if the referee never
// pays — that prevents stale rewards from accumulating indefinitely.
// ============================================================

enum ReferralStatus {
  PENDING   // Referee registered but hasn't paid yet
  REWARDED  // Referee paid; both sides got their reward
  EXPIRED   // 90 days elapsed without payment
}

model Referral {
  id                  String         @id @default(uuid())
  referrerId          String
  refereeId           String         @unique // Each user can be referred only once
  status              ReferralStatus @default(PENDING)
  referralCodeUsed    String         // Snapshot in case codes are regenerated
  registeredAt        DateTime       @default(now())
  rewardedAt          DateTime?
  expiresAt           DateTime       // registeredAt + 90 days
  // Free-form note for ops if a reward is manually adjusted
  notes               String?

  referrer User @relation("ReferralsMade", fields: [referrerId], references: [id])
  referee  User @relation("ReferralReceived", fields: [refereeId], references: [id])

  @@index([referrerId, status])
  @@index([status, expiresAt])
  @@map("referrals")
}

// ============================================================
// PROGRAMMING / WORKOUT BUILDER
// ============================================================

enum ProgramStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

model Program {
  id          String        @id @default(uuid())
  coachId     String
  athleteId   String
  title       String
  description String?
  status      ProgramStatus @default(DRAFT)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  coach   User          @relation("CoachPrograms", fields: [coachId], references: [id])
  athlete User          @relation("AthletePrograms", fields: [athleteId], references: [id])
  weeks   ProgramWeek[]

  @@index([coachId])
  @@index([athleteId, status])
  @@map("programs")
}

model ProgramWeek {
  id        String   @id @default(uuid())
  programId String
  weekNum   Int
  title     String? // "Week 1 — Foundation", etc.
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  program Program      @relation(fields: [programId], references: [id], onDelete: Cascade)
  days    ProgramDay[]

  @@unique([programId, weekNum])
  @@map("program_weeks")
}

model ProgramDay {
  id        String   @id @default(uuid())
  weekId    String
  dayNum    Int // 1-7
  title     String? // "Monday — Throwing Day"
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  week      ProgramWeek       @relation(fields: [weekId], references: [id], onDelete: Cascade)
  exercises ProgramExercise[]

  @@unique([weekId, dayNum])
  @@map("program_days")
}

model ProgramExercise {
  id          String   @id @default(uuid())
  dayId       String
  sortOrder   Int      @default(0)
  exerciseId  String? // link to exercise library, or null for custom
  customName  String? // if not from library
  sets        Int?
  reps        String? // "10" or "8-12" or "AMRAP"
  intensity   String? // "65%" or "RPE 7" or "Max Effort"
  restSeconds Int?
  tempo       String? // "3-1-1-0"
  notes       String? // coach instructions
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  day      ProgramDay @relation(fields: [dayId], references: [id], onDelete: Cascade)
  exercise Exercise?  @relation(fields: [exerciseId], references: [id])

  @@index([dayId, sortOrder])
  @@map("program_exercises")
}

// Exercise library — reusable exercise definitions
model Exercise {
  id          String   @id @default(uuid())
  name        String
  category    String // "throwing", "arm_care", "strength", "mobility", "conditioning"
  equipment   String? // "plyo_ball", "band", "dumbbell", etc.
  description String?
  videoUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  programExercises ProgramExercise[]

  @@index([category])
  @@map("exercises")
}

// ============================================================
// FAMILIES & ATHLETE PROFILES
// ============================================================

model Family {
  id                String   @id @default(uuid())
  parentUserId      String   @unique // The parent/guardian User
  stripeCustomerId  String?  @unique // One Stripe customer per family
  primaryLocationId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  parent          User             @relation("FamilyParent", fields: [parentUserId], references: [id])
  primaryLocation Location?        @relation(fields: [primaryLocationId], references: [id])
  athletes        AthleteProfile[]

  @@map("families")
}

model AthleteProfile {
  id                   String                      @id @default(uuid())
  userId               String                      @unique // The athlete's own User account
  familyId             String? // null for INDIVIDUAL or PARTNER_SCHOOL
  schoolTeamId         String? // null unless PARTNER_SCHOOL
  relationToParent     AthleteRelationType         @default(SELF)
  firstName            String
  lastName             String
  dateOfBirth          DateTime?
  ageGroup             String? // "youth", "ms_hs", "college", "pro" — SOURCE OF TRUTH for an athlete's playing level. ClientProfile.ageGroup also exists (legacy) but should be treated as a cache; always read from here. Keep them in sync when updating via `$transaction`. See audit issue #11.
  trainingDeliveryPref TrainingDeliveryPreference?
  lastAgeMovedUpAlert  DateTime? // Last time we sent the "move up" notification
  parentOptOut         Boolean                     @default(false) // College athlete opted out of adding parent
  parentOptOutAckedAt  DateTime? // When they acknowledged responsibility
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt

  // Relations
  user             User               @relation("AthleteUser", fields: [userId], references: [id], onDelete: Cascade)
  family           Family?            @relation(fields: [familyId], references: [id])
  schoolTeam       SchoolTeam?        @relation(fields: [schoolTeamId], references: [id])
  onboardingRecord OnboardingRecord?
  memberships      ClientMembership[]

  outsideCoachLinks OutsideCoachLink[]
  liabilityWaivers  LiabilityWaiverSignature[]
  // Medical screenings this athlete has been scheduled for / completed
  medicalScreenings MedicalScreening[]

  // Tagging + custom fields (Phase 1A + 1B)
  tagAssignments    TagAssignment[]    @relation("AthleteTags")
  customFieldValues CustomFieldValue[] @relation("AthleteCustomFields")

  @@index([familyId])
  @@index([schoolTeamId])
  @@index([ageGroup])
  @@map("athlete_profiles")
}

// ============================================================
// OUTSIDE COACH LINKS
// ============================================================

/**
 * Links an athlete to their non-PPL coaches (high school, travel ball, etc.)
 * Outside coaches get read-only access to: metrics, reports, and coach notes.
 * They CANNOT book, edit, or see scheduling info — just performance data.
 */
model OutsideCoachLink {
  id           String            @id @default(uuid())
  athleteId    String
  coachName    String // Full name of the outside coach
  coachEmail   String // Email for reports / login
  coachPhone   String?
  organization String? // "Central High School", "Louisville Sluggers Travel", etc.
  // Legacy free-form coach role string — kept for existing rows. New data should
  // set `coachType` below instead. A follow-up migration can backfill coachType
  // from coachRole once we're confident in the enum values.
  coachRole    String? // "Head Coach", "Pitching Coach", "Travel Coach", etc.
  // Structured coach type — drives the "Message from [Athlete]'s [CoachType]"
  // subject line when this outside coach messages admin/coordinator. Nullable
  // so pre-migration rows remain valid until Chad (or a backfill) sets it.
  coachType    OutsideCoachType?
  isActive     Boolean           @default(true)
  invitedAt    DateTime          @default(now())
  acceptedAt   DateTime? // When the coach claimed their account
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  // Relations
  athlete AthleteProfile @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  @@unique([athleteId, coachEmail])
  @@index([coachEmail])
  @@map("outside_coach_links")
}

model OnboardingRecord {
  id                 String              @id @default(uuid())
  // Which org's onboarding fee was paid — matters because Renewed Performance
  // will be paid per-athlete by whichever org onboarded them.
  organizationId     String              @default("ppl")
  athleteId          String              @unique
  onboardingStatus   OnboardingStatus    @default(NEW)
  feeStatus          OnboardingFeeStatus @default(REQUIRED)
  onboardingFeeCents Int                 @default(30000) // $300.00
  stripePaymentId    String? // Stripe PI for the onboarding fee
  stripeCheckoutId   String? // Stripe Checkout Session ID
  isYouthGraduate    Boolean             @default(false) // Graduated from PPL Youth → still NEW but gets special messaging
  hadFreeAssessment  Boolean             @default(false) // Did a free assessment but never trained
  qualifyingAnswers  Json? // { "trainedBefore": false, "lastTrainedDate": null, ... }
  selfReportedStatus String? // What the athlete selected: "new", "returning", "youth_graduate", "free_assessment"
  completedAt        DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  // Relations
  athlete AthleteProfile @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("onboarding_records")
}

// ============================================================
// PARTNER SCHOOL TEAMS
// ============================================================

model SchoolTeam {
  id                String         @id @default(uuid())
  name              String // "Lexington Catholic Baseball"
  slug              String         @unique // "lexington-catholic" — used in signup URL
  // Which partner-school segment this team belongs to. Drives dashboard
  // variant selection (HS vs Travel vs College) per Chad's spec.
  // Default HIGH_SCHOOL keeps existing rows valid without a manual backfill.
  type              SchoolTeamType @default(HIGH_SCHOOL)
  primaryLocationId String?
  brandLogoUrl      String? // Uploaded school logo
