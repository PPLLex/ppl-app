enum MetricType {
  FASTBALL_VELO
  CHANGEUP_VELO
  CURVEBALL_VELO
  SLIDER_VELO
  CUTTER_VELO
  SPIN_RATE
  COMMAND_SCORE
  MECHANICAL_SCORE
  BODY_WEIGHT
  CUSTOM
}

enum PaymentStatus {
  SUCCEEDED
  FAILED
  RETRYING
  REFUNDED
}

enum CardChangeRequestStatus {
  PENDING
  LINK_SENT
  COMPLETED
  DENIED
}

enum NotificationType {
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  BOOKING_REMINDER
  PAYMENT_SUCCEEDED
  PAYMENT_FAILED
  CREDITS_REVOKED
  CREDITS_RESTORED
  NEW_MESSAGE
  SCHEDULE_CHANGED
  MEMBERSHIP_STATUS_CHANGE
}

enum NotificationChannel {
  EMAIL
  SMS
  PUSH
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

// ============================================================
// ORGANIZATIONS — top-level tenant layer
// ============================================================
// Every business entity lives under an Organization. PPL is the first org,
// HPL and Renewed Performance come online as separate brands. Apps share
// the same backend + DB; each app reads org context from its domain or the
// user's memberships and filters all queries by organizationId. See
// ARCHITECTURE.md at the repo root for the rules and phases.
//
// The four seeded orgs use their slugs as primary keys (not UUIDs) so code
// and SQL can reference them readably:
//   - "ppl"                  Pitching Performance Lab
//   - "hpl"                  Hitting Performance Lab
//   - "hpl-youth"            HPL Youth (sub-brand, may consolidate into hpl)
//   - "renewed-performance"  Renewed Performance (screenings, no client memberships)

model Organization {
  id        String  @id // slug used as ID: "ppl", "hpl", ...
  name      String // "Pitching Performance Lab"
  shortName String // "PPL"
  tagline   String?

  // Branding
  logoUrl      String?
  logoData     String? // base64 fallback
  primaryColor String  @default("#5E9E50")
  accentColor  String  @default("#95C83C")

  // Domain routing — used by the frontend OrgContext to pick the active org
  primaryDomain     String?  @unique // e.g., "app.pitchingperformancelab.com"
  additionalDomains String[] @default([])

  // Stripe — charges for this org's memberships land on this account.
  // Joint memberships are charged once on the originating app's Stripe account
  // and reconciled via the revenue ledger (see services/revenueLedger.ts).
  stripeAccountId String?

  // Defaults used when creating sessions/rooms in this org
  defaultCapacity         Int @default(8)
  sessionDurationMinutes  Int @default(60)
  registrationCutoffHours Int @default(1)
  cancellationCutoffHours Int @default(6)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("organizations")
}

// ============================================================
// LOCATIONS
// ============================================================

model Location {
  id             String   @id @default(uuid())
  name           String
  address        String?
  phone          String?
  timezone       String   @default("America/Chicago")
  operatingHours Json? // { monday: { open: "06:00", close: "21:00" }, ... }
  closedDay      String? // e.g., "sunday"
  kioskPin       String? // 4-6 digit PIN for self-service kiosk check-in
  // See ARCHITECTURE.md — every org-tagged table defaults to "ppl" so existing
  // rows land on PPL when the column is added, and Organization FK is added
  // in a follow-up migration once the 4 orgs are seeded.
  organizationId String   @default("ppl")
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  users                User[]
  staffLocations       StaffLocation[]
  rooms                Room[]
  sessions             Session[]
  clientMemberships    ClientMembership[]
  conversations        Conversation[]
  auditLogs            AuditLog[]
  families             Family[]
  schoolTeams          SchoolTeam[]
  scheduleTemplates    ScheduleTemplate[]
  sessionTypeConfigs   SessionTypeConfig[]
  attendanceViolations AttendanceViolation[]
  // UserRole assignments scoped to this location (COORDINATOR,
  // PERFORMANCE_COACH, CONTENT_MARKETING, MEDICAL, MEDICAL_ADMIN roles).
  userRoles            UserRole[]
  // Leads interested in this location.
  leads                Lead[]
  // Medical screenings held at this location — drives the weekly revenue
  // report grouped by location for the Medical Admin.
  medicalScreenings    MedicalScreening[]

  @@index([organizationId])
  @@map("locations")
}

// ============================================================
// USERS & AUTH
// ============================================================

model User {
  id               String  @id @default(uuid())
  email            String  @unique
  passwordHash     String? // Optional — null for OAuth-only accounts
  fullName         String
  phone            String?
  role             Role    @default(CLIENT)
  homeLocationId   String?
  isActive         Boolean @default(true)
  stripeCustomerId String? @unique

  // Family & account type fields
  accountType  AccountType @default(INDIVIDUAL)
  isParent     Boolean     @default(false)
  parentUserId String? // Self-ref: college athletes who opt out of adding a parent

  // OAuth fields
  authProvider String? // "email", "google", "apple" — primary auth method
  googleId     String? @unique
  appleId      String? @unique
  avatarUrl    String?

  // Magic link fields
  magicLinkToken  String?   @unique
  magicLinkExpiry DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  homeLocation       Location?           @relation(fields: [homeLocationId], references: [id])
  parentUser         User?               @relation("ParentChild", fields: [parentUserId], references: [id])
  childUsers         User[]              @relation("ParentChild")
  clientProfile      ClientProfile?
  family             Family?             @relation("FamilyParent")
  athleteProfile     AthleteProfile?     @relation("AthleteUser")
  staffLocations     StaffLocation[]
  coachedSessions    Session[]           @relation("SessionCoach")
  bookings           Booking[]
  clientMemberships  ClientMembership[]
  weeklyCredits      WeeklyCredit[]
  payments           Payment[]
  cardChangeRequests CardChangeRequest[] @relation("ClientCardRequests")
  adminCardRequests  CardChangeRequest[] @relation("AdminCardRequests")
  sentMessages       Message[]
  notifications      Notification[]
  pushTokens         PushToken[]
  auditLogs          AuditLog[]

  // Coach Notes relations
  athleteNotes     CoachNote[]       @relation("AthleteNotes")
  coachNotes       CoachNote[]       @relation("CoachNotes")
  athleteDigests   NoteDigest[]      @relation("AthleteDigests")
  digestRecipients DigestRecipient[] @relation("DigestRecipients")

  // Goals & Forms relations
  athleteGoals  Goal[]         @relation("AthleteGoals")
  coachGoals    Goal[]         @relation("CoachGoals")
  createdForms  FormTemplate[] @relation("CreatedForms")
  formResponses FormResponse[] @relation("FormResponses")

  // Programming relations
  coachPrograms   Program[] @relation("CoachPrograms")
  athletePrograms Program[] @relation("AthletePrograms")

  // Metrics relations
  athleteMetrics    AthleteMetric[] @relation("AthleteMetrics")
  staffCoachMetrics AthleteMetric[] @relation("StaffCoachMetrics")

  // Schedule template & violation relations
  scheduleTemplates    ScheduleTemplate[]    @relation("TemplateCoach")
  attendanceViolations AttendanceViolation[] @relation("ViolationClient")
  assessedViolations   AttendanceViolation[] @relation("ViolationAssessor")

  // Liability waiver signatures this user signed (as the signing adult — parent or self)
  signedWaivers LiabilityWaiverSignature[]

  // Role assignments — a user can hold multiple roles simultaneously (e.g. a
  // Performance Coach who also does Content & Marketing). Supersedes the
  // single `role` column above during the April 2026 role-model migration.
  // See schema.prisma Role enum comment for the full list.
  userRoles UserRole[]

  // CRM relations — staff-side (ownedLeads, loggedLeadActivities) + the
  // reverse link from the Lead that converted into this user (nullable
  // because direct signups don't have a preceding Lead row).
  ownedLeads           Lead[]         @relation("LeadOwner")
  convertedFromLead    Lead?          @relation("LeadConverted")
  loggedLeadActivities LeadActivity[] @relation("LeadActivityAuthor")

  // Medical screenings this user is the PROVIDER for (MEDICAL /
  // MEDICAL_ADMIN roles). Null providerUserId on a screening means
  // it's been scheduled but not yet assigned to a PT.
  providedScreenings MedicalScreening[] @relation("ScreeningProvider")

  @@index([homeLocationId])
  @@index([role])
  @@index([email])
  @@map("users")
}

/// Multi-role assignment — a user can have 1+ UserRole rows. This supersedes
/// the single `User.role` column, which is kept for backward compat during
/// the transition.
///
/// Scoping semantics (nullable per row depending on role):
///   - Global roles (ADMIN, CONTENT_MARKETING_ADMIN, MEDICAL_ADMIN, PARENT,
///     ATHLETE): locationId=null, schoolTeamId=null
///   - Location-scoped roles (COORDINATOR, PERFORMANCE_COACH,
///     CONTENT_MARKETING, MEDICAL): locationId=X, schoolTeamId=null
///   - Partnership Coach: locationId=null, schoolTeamId=X (1 row per school)
///   - Outside Coach: represented elsewhere via OutsideCoachLink rows
///
/// A user who's a Performance Coach at TWO locations gets TWO rows (one per
/// locationId). A user who's both a Performance Coach and a Content &
/// Marketing team member at Lexington gets TWO rows (different role, same
/// locationId). The UNIQUE constraint prevents accidental duplicates of the
/// same (user, role, location, school) tuple.
model UserRole {
  id           String   @id @default(uuid())
  userId       String
  role         Role
  // Null for global roles (ADMIN, CONTENT_MARKETING_ADMIN, MEDICAL_ADMIN,
  // PARENT, ATHLETE) and for Partnership Coach (scoped by schoolTeamId).
  locationId   String?
  // Set ONLY when role=PARTNERSHIP_COACH — one row per partner school this
  // coach is responsible for.
  schoolTeamId String?
  createdAt    DateTime @default(now())

  // Relations
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  location   Location?   @relation(fields: [locationId], references: [id])
  schoolTeam SchoolTeam? @relation(fields: [schoolTeamId], references: [id])

  @@unique([userId, role, locationId, schoolTeamId])
  @@index([userId])
  @@index([role, locationId])
  @@index([schoolTeamId])
  @@map("user_roles")
}

model ClientProfile {
  id                    String                      @id @default(uuid())
  userId                String                      @unique
  ageGroup              String? // "youth", "ms_hs", "college"
  dateOfBirth           DateTime?
  emergencyContactName  String?
  emergencyContactPhone String?
  trainingGoals         String?
  trainingPreference    TrainingDeliveryPreference?
  notes                 String?
  waiverSignedAt        DateTime?
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("client_profiles")
}

model StaffLocation {
  id         String         @id @default(uuid())
  staffId    String
  locationId String
  roles      LocationRole[] @default([COACH])
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  // Relations
  staff    User     @relation(fields: [staffId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([staffId, locationId])
  @@index([locationId])
  @@map("staff_locations")
}

model StaffInvite {
  id        String    @id @default(uuid())
  email     String
  fullName  String
  phone     String?
  token     String    @unique @default(uuid())
  role      Role      @default(STAFF)
  locations Json // [{locationId, roles: ['PITCHING_COORDINATOR', ...]}]
  expiresAt DateTime
  usedAt    DateTime?
  invitedBy String?
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([email])
  @@map("staff_invites")
}

// ============================================================
// ROOMS & SCHEDULING
// ============================================================

model Room {
  id         String   @id @default(uuid())
  locationId String
  name       String
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  location          Location           @relation(fields: [locationId], references: [id], onDelete: Cascade)
  sessions          Session[]
  scheduleTemplates ScheduleTemplate[]

  @@index([locationId])
  @@map("rooms")
}

model Session {
  id                      String      @id @default(uuid())
  organizationId          String      @default("ppl")
  locationId              String
  roomId                  String?
  coachId                 String?
  title                   String
  sessionType             SessionType
  startTime               DateTime
  endTime                 DateTime
  maxCapacity             Int         @default(8)
  currentEnrolled         Int         @default(0)
  recurringRule           String? // iCal RRULE format
  recurringGroupId        String? // links recurring instances
  registrationCutoffHours Int         @default(2)
  cancellationCutoffHours Int         @default(4)
  isActive                Boolean     @default(true)
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  // Relations
  location             Location              @relation(fields: [locationId], references: [id])
  room                 Room?                 @relation(fields: [roomId], references: [id])
  coach                User?                 @relation("SessionCoach", fields: [coachId], references: [id])
  bookings             Booking[]
  attendanceViolations AttendanceViolation[]

  @@index([organizationId, startTime])
  @@index([locationId, startTime])
  @@index([coachId])
  @@index([sessionType])
  @@index([recurringGroupId])
  @@map("sessions")
}

model Booking {
  id                 String        @id @default(uuid())
  clientId           String
  sessionId          String
  status             BookingStatus @default(CONFIRMED)
  creditsUsed        Int           @default(1)
  cancelledAt        DateTime?
  cancellationReason String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  // Relations
  client             User                @relation(fields: [clientId], references: [id])
  session            Session             @relation(fields: [sessionId], references: [id])
  creditTransactions CreditTransaction[]
  coachNotes         CoachNote[]

  @@unique([clientId, sessionId])
  @@index([clientId, status])
  @@index([sessionId])
  @@map("bookings")
}

// ============================================================
// ATTENDANCE VIOLATIONS & FINES
// ============================================================

enum ViolationType {
  NO_SIGNUP // Showed up without booking ($20 fine)
  WRONG_TIME // Showed up at incorrect session time ($10 fine)
}

enum ViolationStatus {
  PENDING // Fine assessed, not yet paid
  PAID // Fine collected via Stripe
  WAIVED // Admin waived the fine
}

model AttendanceViolation {
  id           String          @id @default(uuid())
  clientId     String
  sessionId    String? // Which session they walked into (null if no specific session)
  locationId   String
  type         ViolationType
  amountCents  Int // 2000 = $20, 1000 = $10
  status       ViolationStatus @default(PENDING)
  notes        String? // Coach/admin notes on what happened
  assessedById String // Staff/admin who logged it
  paidAt       DateTime?
  waivedAt     DateTime?
  waivedById   String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  client     User     @relation("ViolationClient", fields: [clientId], references: [id])
  session    Session? @relation(fields: [sessionId], references: [id])
  location   Location @relation(fields: [locationId], references: [id])
  assessedBy User     @relation("ViolationAssessor", fields: [assessedById], references: [id])

  @@index([clientId])
  @@index([sessionId])
  @@index([status])
  @@map("attendance_violations")
}

/// Admin-defined weekly schedule template.
/// Each entry is "every Monday at 3pm in Room A, College Pitching".
/// A cron job uses these to auto-generate Session rows 2 weeks ahead.
model ScheduleTemplate {
  id                      String      @id @default(uuid())
  organizationId          String      @default("ppl")
  locationId              String
  roomId                  String?
  coachId                 String?
  title                   String
  sessionType             SessionType
  dayOfWeek               Int // 0=Sunday … 6=Saturday
  startHour               Int // 0-23
  startMinute             Int         @default(0)
  durationMinutes         Int         @default(60)
  maxCapacity             Int         @default(8)
  registrationCutoffHours Int         @default(2)
  cancellationCutoffHours Int         @default(4)
  isActive                Boolean     @default(true)
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  location Location @relation(fields: [locationId], references: [id])
  room     Room?    @relation(fields: [roomId], references: [id])
  coach    User?    @relation("TemplateCoach", fields: [coachId], references: [id])

  @@index([organizationId])
  @@index([locationId, dayOfWeek])
  @@map("schedule_templates")
}

// ============================================================
// SESSION TYPE CONFIGURATION  (per-location defaults per type)
// ============================================================

model SessionTypeConfig {
  id                      String      @id @default(uuid())
  organizationId          String      @default("ppl")
  locationId              String
  sessionType             SessionType
  label                   String // Display name, e.g. "College Pitching"
  maxCapacity             Int         @default(8)
  durationMinutes         Int         @default(60)
  registrationCutoffHours Int         @default(2)
  cancellationCutoffHours Int         @default(4)
  color                   String? // Hex color for calendar display, e.g. "#10B981"
  isActive                Boolean     @default(true)
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  location Location @relation(fields: [locationId], references: [id])

  @@unique([locationId, sessionType])
  @@index([organizationId])
  @@map("session_type_configs")
}

// ============================================================
// MEMBERSHIPS & BILLING
// ============================================================

model MembershipPlan {
  id               String   @id @default(uuid())
  organizationId   String   @default("ppl")
  name             String // "Unlimited College Pitching", "Youth 1x/Week", etc.
  slug             String   @unique
  ageGroup         String // "college", "ms_hs", "youth"
  sessionsPerWeek  Int? // null = unlimited
  priceCents       Int // e.g., 8500 = $85.00
  billingCycle     String   @default("weekly")
  description      String?
  isActive         Boolean  @default(true)
  // Discipline / bundling.
  //   includesHitting   — this plan covers hitting training in addition to pitching.
  //                       On PPL app, hitting is only available as an add-on; the
  //                       registration UI offers a "+ Add Hitting" toggle that
  //                       swaps the user to the paired combo plan.
  //   pairedWithPlanId  — points to the sibling plan in the pitching/combo pair.
  //                       A pitching-only plan points to its combo; the combo
  //                       points back to the pitching-only plan. Always bidirectional
  //                       so the UI can navigate either direction.
  //   revenueSplits     — how the weekly (or monthly) priceCents is divided
  //                       BETWEEN BUSINESSES. JSON object keyed by org slug, values
  //                       in cents. MUST sum to priceCents. Example:
  //                         { "ppl": 5000, "hpl": 4000 }  for a $90/wk Youth combo.
  //                       Pitching-only plans are 100% PPL → { "ppl": <priceCents> }.
  //                       Used by the weekly inter-business settlement report.
  includesHitting  Boolean  @default(false)
  pairedWithPlanId String?
  revenueSplits    Json     @default("{}")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  clientMemberships ClientMembership[]

  @@index([organizationId])
  @@map("membership_plans")
}

model ClientMembership {
  id                   String           @id @default(uuid())
  clientId             String
  planId               String
  locationId           String
  athleteId            String? // Links to AthleteProfile — null for legacy memberships
  status               MembershipStatus @default(ACTIVE)
  stripeSubscriptionId String?          @unique
  stripePriceId        String?
  billingDay           BillingDay
  billingAnchorDate    DateTime
  startedAt            DateTime         @default(now())
  cancelledAt          DateTime?
  cancelRequestedAt    DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  // Relations
  client        User            @relation(fields: [clientId], references: [id])
  plan          MembershipPlan  @relation(fields: [planId], references: [id])
  location      Location        @relation(fields: [locationId], references: [id])
  athlete       AthleteProfile? @relation(fields: [athleteId], references: [id])
  weeklyCredits WeeklyCredit[]
  payments      Payment[]

  @@index([clientId, status])
  @@index([status])
  @@index([billingDay])
  @@map("client_memberships")
}

model WeeklyCredit {
  id             String   @id @default(uuid())
  // org is direct here because joint memberships split credits into pools
  // tagged per-org (1 PPL credit + 1 HPL credit, never cross-spendable).
  // Filtering credits by org is a hot path.
  organizationId String   @default("ppl")
  clientId       String
  membershipId   String
  creditsTotal   Int
  creditsUsed    Int      @default(0)
  weekStartDate  DateTime
  weekEndDate    DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  client     User             @relation(fields: [clientId], references: [id])
  membership ClientMembership @relation(fields: [membershipId], references: [id])

  @@unique([clientId, membershipId, weekStartDate])
  @@index([clientId, weekStartDate])
  @@index([organizationId, weekStartDate])
  @@map("weekly_credits")
}

model CreditTransaction {
  id              String   @id @default(uuid())
  clientId        String
  transactionType String // "usage", "refund", "revoke", "restore"
  amount          Int // positive = added, negative = used/revoked
  bookingId       String?
  paymentId       String?
  notes           String?
  createdAt       DateTime @default(now())

  // Relations
  booking Booking? @relation(fields: [bookingId], references: [id])

  @@index([clientId, createdAt])
  @@map("credit_transactions")
}

// ============================================================
// PAYMENTS
// ============================================================

model Payment {
  id                    String        @id @default(uuid())
  clientId              String
  membershipId          String?
  stripePaymentIntentId String?       @unique
  stripeInvoiceId       String?       @unique
  amountCents           Int
  status                PaymentStatus
  failureReason         String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  // Relations
  client     User              @relation(fields: [clientId], references: [id])
  membership ClientMembership? @relation(fields: [membershipId], references: [id])

  @@index([clientId, createdAt])
  @@index([status])
  @@map("payments")
}

model CardChangeRequest {
  id               String                  @id @default(uuid())
  clientId         String
  adminId          String?
  status           CardChangeRequestStatus @default(PENDING)
  secureLinkToken  String?                 @unique
  secureLinkExpiry DateTime?
  newCardVerified  Boolean                 @default(false)
  notes            String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  // Relations
  client User  @relation("ClientCardRequests", fields: [clientId], references: [id])
  admin  User? @relation("AdminCardRequests", fields: [adminId], references: [id])

  @@index([clientId])
  @@index([status])
  @@map("card_change_requests")
}

// ============================================================
// MESSAGING
// ============================================================

model Conversation {
  id           String   @id @default(uuid())
  locationId   String?
  participants Json // array of user IDs
  type         String // "client_coach", "client_admin"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  location Location? @relation(fields: [locationId], references: [id])
  messages Message[]

  @@map("conversations")
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  readBy         Json     @default("[]") // array of user IDs who have read
  createdAt      DateTime @default(now())

  // Relations
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id])

  @@index([conversationId, createdAt])
  @@map("messages")
}

// ============================================================
// NOTIFICATIONS
// ============================================================

model Notification {
  id        String              @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  channel   NotificationChannel
  status    NotificationStatus  @default(PENDING)
  metadata  Json? // extra data (booking ID, payment amount, etc.)
  sentAt    DateTime?
  createdAt DateTime            @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([status])
  @@map("notifications")
}

// ============================================================
// PUSH NOTIFICATION TOKENS
// ============================================================

model PushToken {
  id         String   @id @default(uuid())
  userId     String
  token      String   @unique // FCM device token
  deviceInfo String? // "Chrome on Windows", "Safari on iPhone", etc.
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_tokens")
}

// ============================================================
// COACH SESSION NOTES
// ============================================================

enum TrainingCategory {
  PITCHING_MECHANICS
  VELOCITY_TRAINING
  ARM_CARE
  BULLPEN_SESSION
  LIVE_AT_BATS
  VIDEO_REVIEW
  STRENGTH_CONDITIONING
  MENTAL_PERFORMANCE
  GENERAL
  OTHER
}

model CoachNote {
  id               String           @id @default(uuid())
  athleteId        String
  coachId          String? // PPL staff coach (null if school coach)
  schoolCoachId    String? // Partner school coach (null if PPL staff)
  trainingCategory TrainingCategory
  rawContent       String // original note from coach
  cleanedContent   String? // AI-cleaned version (grammar, profanity filtered)
  sessionDate      DateTime         @default(now())
  bookingId        String? // optional link to a specific booking
  isVisible        Boolean          @default(true) // can be hidden if needed
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  // Relations
  athlete     User         @relation("AthleteNotes", fields: [athleteId], references: [id])
  coach       User?        @relation("CoachNotes", fields: [coachId], references: [id])
  schoolCoach SchoolCoach? @relation("SchoolCoachNotes", fields: [schoolCoachId], references: [id])
  booking     Booking?     @relation(fields: [bookingId], references: [id])

  @@index([athleteId, createdAt])
  @@index([coachId, createdAt])
  @@index([schoolCoachId, createdAt])
  @@index([athleteId, trainingCategory])
  @@map("coach_notes")
}

// Weekly email digest tracking
model NoteDigest {
  id          String    @id @default(uuid())
  athleteId   String
  weekStart   DateTime
  weekEnd     DateTime
  emailSentAt DateTime?
  recipients  Json // array of email addresses that received this digest
  noteIds     Json // array of CoachNote IDs included
  htmlContent String? // rendered email content for audit
  createdAt   DateTime  @default(now())

  // Relations
  athlete User @relation("AthleteDigests", fields: [athleteId], references: [id])

  @@unique([athleteId, weekStart])
  @@index([weekStart])
  @@map("note_digests")
}

// Additional email recipients per athlete (parent emails, on-field coaches, etc.)
model DigestRecipient {
  id        String   @id @default(uuid())
  athleteId String
  email     String
  name      String?
  relation  String? // "parent", "coach", "guardian", etc.
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  athlete User @relation("DigestRecipients", fields: [athleteId], references: [id])

  @@unique([athleteId, email])
  @@map("digest_recipients")
}

// ============================================================
// GOALS & GAMIFICATION
// ============================================================

enum GoalType {
  SHORT_TERM // weeks
  LONG_TERM // months/season
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  ABANDONED
}

model Goal {
  id          String     @id @default(uuid())
  athleteId   String
  coachId     String? // coach who set it, or null if self-set
  type        GoalType
  title       String
  description String?
  targetDate  DateTime?
  status      GoalStatus @default(ACTIVE)
  progress    Int        @default(0) // 0-100 percentage
  completedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Relations
  athlete User  @relation("AthleteGoals", fields: [athleteId], references: [id])
  coach   User? @relation("CoachGoals", fields: [coachId], references: [id])

  @@index([athleteId, status])
  @@index([athleteId, type])
  @@map("goals")
}

// ============================================================
// CUSTOM FORMS (onboarding, questionnaires, intake, etc.)
// ============================================================

model FormTemplate {
  id           String   @id @default(uuid())
  createdById  String
  title        String
  description  String?
  fields       Json // array of field definitions: [{name, type, label, required, options}]
  isOnboarding Boolean  @default(false) // if true, new athletes must fill it out
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  createdBy User           @relation("CreatedForms", fields: [createdById], references: [id])
  responses FormResponse[]

  @@map("form_templates")
}

model FormResponse {
  id        String   @id @default(uuid())
  formId    String
  athleteId String
  answers   Json // { fieldName: answer, ... }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  form    FormTemplate @relation(fields: [formId], references: [id])
  athlete User         @relation("FormResponses", fields: [athleteId], references: [id])

  @@unique([formId, athleteId]) // one response per athlete per form (can update)
  @@index([athleteId])
  @@map("form_responses")
}

// ============================================================
// PROGRAMMING / WORKOUT BUILDER
// ============================================================

enum ProgramStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

model Program {
  id          String        @id @default(uuid())
  coachId     String
  athleteId   String
  title       String
  description String?
  status      ProgramStatus @default(DRAFT)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  coach   User          @relation("CoachPrograms", fields: [coachId], references: [id])
  athlete User          @relation("AthletePrograms", fields: [athleteId], references: [id])
  weeks   ProgramWeek[]

  @@index([coachId])
  @@index([athleteId, status])
  @@map("programs")
}

model ProgramWeek {
  id        String   @id @default(uuid())
  programId String
  weekNum   Int
  title     String? // "Week 1 — Foundation", etc.
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  program Program      @relation(fields: [programId], references: [id], onDelete: Cascade)
  days    ProgramDay[]

  @@unique([programId, weekNum])
  @@map("program_weeks")
}

model ProgramDay {
  id        String   @id @default(uuid())
  weekId    String
  dayNum    Int // 1-7
  title     String? // "Monday — Throwing Day"
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  week      ProgramWeek       @relation(fields: [weekId], references: [id], onDelete: Cascade)
  exercises ProgramExercise[]

  @@unique([weekId, dayNum])
  @@map("program_days")
}

model ProgramExercise {
  id          String   @id @default(uuid())
  dayId       String
  sortOrder   Int      @default(0)
  exerciseId  String? // link to exercise library, or null for custom
  customName  String? // if not from library
  sets        Int?
  reps        String? // "10" or "8-12" or "AMRAP"
  intensity   String? // "65%" or "RPE 7" or "Max Effort"
  restSeconds Int?
  tempo       String? // "3-1-1-0"
  notes       String? // coach instructions
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  day      ProgramDay @relation(fields: [dayId], references: [id], onDelete: Cascade)
  exercise Exercise?  @relation(fields: [exerciseId], references: [id])

  @@index([dayId, sortOrder])
  @@map("program_exercises")
}

// Exercise library — reusable exercise definitions
model Exercise {
  id          String   @id @default(uuid())
  name        String
  category    String // "throwing", "arm_care", "strength", "mobility", "conditioning"
  equipment   String? // "plyo_ball", "band", "dumbbell", etc.
  description String?
  videoUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  programExercises ProgramExercise[]

  @@index([category])
  @@map("exercises")
}

// ============================================================
// FAMILIES & ATHLETE PROFILES
// ============================================================

model Family {
  id                String   @id @default(uuid())
  parentUserId      String   @unique // The parent/guardian User
  stripeCustomerId  String?  @unique // One Stripe customer per family
  primaryLocationId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  parent          User             @relation("FamilyParent", fields: [parentUserId], references: [id])
  primaryLocation Location?        @relation(fields: [primaryLocationId], references: [id])
  athletes        AthleteProfile[]

  @@map("families")
}

model AthleteProfile {
  id                   String                      @id @default(uuid())
  userId               String                      @unique // The athlete's own User account
  familyId             String? // null for INDIVIDUAL or PARTNER_SCHOOL
  schoolTeamId         String? // null unless PARTNER_SCHOOL
  relationToParent     AthleteRelationType         @default(SELF)
  firstName            String
  lastName             String
  dateOfBirth          DateTime?
  ageGroup             String? // "youth", "ms_hs", "college", "pro" — SOURCE OF TRUTH for an athlete's playing level. ClientProfile.ageGroup also exists (legacy) but should be treated as a cache; always read from here. Keep them in sync when updating via `$transaction`. See audit issue #11.
  trainingDeliveryPref TrainingDeliveryPreference?
  lastAgeMovedUpAlert  DateTime? // Last time we sent the "move up" notification
  parentOptOut         Boolean                     @default(false) // College athlete opted out of adding parent
  parentOptOutAckedAt  DateTime? // When they acknowledged responsibility
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt

  // Relations
  user             User               @relation("AthleteUser", fields: [userId], references: [id], onDelete: Cascade)
  family           Family?            @relation(fields: [familyId], references: [id])
  schoolTeam       SchoolTeam?        @relation(fields: [schoolTeamId], references: [id])
  onboardingRecord OnboardingRecord?
  memberships      ClientMembership[]

  outsideCoachLinks OutsideCoachLink[]
  liabilityWaivers  LiabilityWaiverSignature[]
  // Medical screenings this athlete has been scheduled for / completed
  medicalScreenings MedicalScreening[]

  @@index([familyId])
  @@index([schoolTeamId])
  @@index([ageGroup])
  @@map("athlete_profiles")
}

// ============================================================
// OUTSIDE COACH LINKS
// ============================================================

/**
 * Links an athlete to their non-PPL coaches (high school, travel ball, etc.)
 * Outside coaches get read-only access to: metrics, reports, and coach notes.
 * They CANNOT book, edit, or see scheduling info — just performance data.
 */
model OutsideCoachLink {
  id           String            @id @default(uuid())
  athleteId    String
  coachName    String // Full name of the outside coach
  coachEmail   String // Email for reports / login
  coachPhone   String?
  organization String? // "Central High School", "Louisville Sluggers Travel", etc.
  // Legacy free-form coach role string — kept for existing rows. New data should
  // set `coachType` below instead. A follow-up migration can backfill coachType
  // from coachRole once we're confident in the enum values.
  coachRole    String? // "Head Coach", "Pitching Coach", "Travel Coach", etc.
  // Structured coach type — drives the "Message from [Athlete]'s [CoachType]"
  // subject line when this outside coach messages admin/coordinator. Nullable
  // so pre-migration rows remain valid until Chad (or a backfill) sets it.
  coachType    OutsideCoachType?
  isActive     Boolean           @default(true)
  invitedAt    DateTime          @default(now())
  acceptedAt   DateTime? // When the coach claimed their account
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  // Relations
  athlete AthleteProfile @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  @@unique([athleteId, coachEmail])
  @@index([coachEmail])
  @@map("outside_coach_links")
}

model OnboardingRecord {
  id                 String              @id @default(uuid())
  // Which org's onboarding fee was paid — matters because Renewed Performance
  // will be paid per-athlete by whichever org onboarded them.
  organizationId     String              @default("ppl")
  athleteId          String              @unique
  onboardingStatus   OnboardingStatus    @default(NEW)
  feeStatus          OnboardingFeeStatus @default(REQUIRED)
  onboardingFeeCents Int                 @default(30000) // $300.00
  stripePaymentId    String? // Stripe PI for the onboarding fee
  stripeCheckoutId   String? // Stripe Checkout Session ID
  isYouthGraduate    Boolean             @default(false) // Graduated from PPL Youth → still NEW but gets special messaging
  hadFreeAssessment  Boolean             @default(false) // Did a free assessment but never trained
  qualifyingAnswers  Json? // { "trainedBefore": false, "lastTrainedDate": null, ... }
  selfReportedStatus String? // What the athlete selected: "new", "returning", "youth_graduate", "free_assessment"
  completedAt        DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  // Relations
  athlete AthleteProfile @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("onboarding_records")
}

// ============================================================
// PARTNER SCHOOL TEAMS
// ============================================================

model SchoolTeam {
  id                String         @id @default(uuid())
  name              String // "Lexington Catholic Baseball"
  slug              String         @unique // "lexington-catholic" — used in signup URL
  // Which partner-school segment this team belongs to. Drives dashboard
  // variant selection (HS vs Travel vs College) per Chad's spec.
  // Default HIGH_SCHOOL keeps existing rows valid without a manual backfill.
  type              SchoolTeamType @default(HIGH_SCHOOL)
  primaryLocationId String?
  brandLogoUrl      String? // Uploaded school logo
  brandColors       Json? // { primary: "#1a3e72", secondary: "#c4a34d" }
  signupUrl         String?        @unique // Generated: /join/team/lexington-catholic

  // Coach info
  coachName         String?
  coachEmail        String?
  coachPhone        String?
  coachInviteToken  String?           @unique // Unique token for coach roster form link
  coachInviteStatus CoachInviteStatus @default(NOT_SENT)
  coachInviteSentAt DateTime?
  rosterSubmittedAt DateTime? // When coach finished submitting the roster

  // Billing contact (may differ from coach)
  paymentContactName  String?
  paymentContactEmail String?
  totalAnnualBudget   Int? // cents — total the school pays
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  primaryLocation Location?        @relation(fields: [primaryLocationId], references: [id])
  athletes        AthleteProfile[]
  invoices        SchoolInvoice[]
  contracts       SchoolContract[]
  coaches         SchoolCoach[]
  // Partnership Coach assignments — users in the PPL app who have the
  // PARTNERSHIP_COACH role for this specific partner school.
  userRoles       UserRole[]

  @@index([slug])
  @@index([coachInviteToken])
  @@map("school_teams")
}

model SchoolInvoice {
  id              String              @id @default(uuid())
  schoolTeamId    String
  stripeInvoiceId String?             @unique
  description     String? // "Fall 2026 Remote Programming — 25 athletes"
  totalCents      Int
  paidCents       Int                 @default(0)
  status          SchoolInvoiceStatus @default(DRAFT)
  dueDate         DateTime?
  sentAt          DateTime?
  paidAt          DateTime?
  periodStart     DateTime?
  periodEnd       DateTime?
  notes           String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  // Relations
  schoolTeam SchoolTeam @relation(fields: [schoolTeamId], references: [id])

  @@index([schoolTeamId, status])
  @@map("school_invoices")
}

model SchoolContract {
  id              String         @id @default(uuid())
  schoolTeamId    String
  title           String // "PPL Remote Training Agreement — Fall 2026"
  terms           String // Full contract text / terms
  startDate       DateTime
  endDate         DateTime
  totalValueCents Int? // Total contract value
  status          ContractStatus @default(DRAFT)
  signatureToken  String?        @unique // Token for the signing link
  signedByName    String? // Name of person who signed
  signedByEmail   String?
  signedAt        DateTime?
  sentAt          DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Relations
  schoolTeam SchoolTeam @relation(fields: [schoolTeamId], references: [id])

  @@index([schoolTeamId])
  @@index([signatureToken])
  @@map("school_contracts")
}

// ============================================================
// PARTNER SCHOOL COACHES (Login accounts for school coaches)
// ============================================================

model SchoolCoach {
  id           String          @id @default(uuid())
  schoolTeamId String
  email        String          @unique
  passwordHash String
  fullName     String
  phone        String?
  role         SchoolCoachRole @default(HEAD_COACH)
  title        String? // "Director of Pitching", "Head Baseball Coach", etc.

  // Access control — admin checks these boxes per coach
  canViewDashboard      Boolean @default(true)
  canTakeNotes          Boolean @default(true)
  canViewPrograms       Boolean @default(true)
  canViewGoals          Boolean @default(true)
  canViewMetrics        Boolean @default(true)
  canMessageAthletes    Boolean @default(false)
  receivesWeeklySummary Boolean @default(true)

  // Push notification subscription (for PWA)
  pushSubscription Json? // Web Push subscription object
  notifyReminders  Boolean @default(true)

  lastLoginAt DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  schoolTeam     SchoolTeam      @relation(fields: [schoolTeamId], references: [id])
  athleteNotes   CoachNote[]     @relation("SchoolCoachNotes")
  athleteMetrics AthleteMetric[] @relation("SchoolCoachMetrics")

  @@index([schoolTeamId])
  @@index([email])
  @@map("school_coaches")
}

// ============================================================
// ATHLETE METRICS (Velo, spin rate, performance tracking)
// ============================================================

model AthleteMetric {
  id            String     @id @default(uuid())
  athleteId     String
  schoolCoachId String? // null if logged by PPL staff
  staffCoachId  String? // null if logged by school coach
  metricType    MetricType
  value         Float // the measurement value
  unit          String? // "mph", "rpm", "/10", "lbs", etc.
  customLabel   String? // label when metricType is CUSTOM
  sessionDate   DateTime   @default(now())
  notes         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  // Relations
  athlete     User         @relation("AthleteMetrics", fields: [athleteId], references: [id])
  schoolCoach SchoolCoach? @relation("SchoolCoachMetrics", fields: [schoolCoachId], references: [id])
  staffCoach  User?        @relation("StaffCoachMetrics", fields: [staffCoachId], references: [id])

  @@index([athleteId, metricType])
  @@index([athleteId, createdAt])
  @@index([schoolCoachId])
  @@map("athlete_metrics")
}

// ============================================================
// AUDIT
// ============================================================

model AuditLog {
  id           String   @id @default(uuid())
  userId       String?
  locationId   String?
  action       String // "session.created", "session.updated", "booking.cancelled", etc.
  resourceType String // "session", "booking", "membership", etc.
  resourceId   String?
  changes      Json? // { before: {...}, after: {...} }
  ipAddress    String?
  createdAt    DateTime @default(now())

  // Relations
  user     User?     @relation(fields: [userId], references: [id])
  location Location? @relation(fields: [locationId], references: [id])

  @@index([userId])
  @@index([resourceType, resourceId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================================
// ORGANIZATION SETTINGS (PPL branding & defaults)
// ============================================================

/**
 * EducationalResource — admin-curated content (videos + guides) that
 * clients see on their parent dashboard. Feeds the EducationalContent
 * widget. Intentionally simple: title + short description + optional
 * video URL + optional body markdown + category tag + visibility flag.
 * Visibility:
 * ageGroupFilter — null = all clients; otherwise comma-separated list
 * of age groups ('youth,ms_hs,college,pro'). Lets admins target,
 * e.g. "only show this to Youth parents."
 * isPublished — simple on/off switch for draft vs live content.
 */
/**
 * PasswordResetToken — durable, DB-backed password reset tokens.
 * The raw token is never stored. We store a SHA-256 hash of the token.
 * When a user hits POST /reset-password with a token, we hash the
 * submitted value and look it up. This means a DB read (leak, backup,
 * rogue DBA) can't be used to hijack a live reset link.
 * Cleanup: expired rows are swept by the normal cleanup cron (every
 * 15 min — see cronService). Rows are also deleted on successful use.
 */
model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique // SHA-256 of the raw token bytes
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model EducationalResource {
  id             String   @id @default(uuid())
  organizationId String   @default("ppl")
  title          String
  description    String
  body           String? // optional markdown body for longer articles
  videoUrl       String? // optional Youtube/Vimeo embed URL
  thumbnailUrl   String? // optional card thumbnail image
  category       String   @default("general") // 'onboarding' | 'mechanics' | 'mindset' | 'perks' | 'general'
  ageGroupFilter String? // null = all; else comma-separated age groups
  sortOrder      Int      @default(0)
  isPublished    Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId, isPublished])
  @@map("educational_resources")
}

/**
 * LiabilityWaiverSignature — an immutable record that a specific athlete
 * signed the liability waiver. Stores the FULL waiver text + version that
 * was shown at signing time so the contract is preserved even when admins
 * later update the master waiver copy.
 * One signature per (athleteProfileId, waiverVersion). If we bump the
 * waiver version, existing athletes must re-sign the new version before
 * their next booking.
 */
model LiabilityWaiverSignature {
  id               String   @id @default(uuid())
  athleteProfileId String
  signedByUserId   String // User who actually clicked "sign" (parent for Youth/MS-HS; the athlete for solo College/Pro)
  signedByName     String // Typed signature name
  athleteName      String // Snapshot of athlete's full name
  waiverVersion    String // e.g. '2026-04-23'
  waiverText       String   @db.Text // Full waiver text snapshot
  ipAddress        String?
  userAgent        String?
  signedAt         DateTime @default(now())

  athleteProfile AthleteProfile @relation(fields: [athleteProfileId], references: [id], onDelete: Cascade)
  signedByUser   User           @relation(fields: [signedByUserId], references: [id])

  @@unique([athleteProfileId, waiverVersion])
  @@index([athleteProfileId])
  @@map("liability_waiver_signatures")
}

model OrgSettings {
  id                     String  @id @default("ppl") // singleton row
  businessName           String  @default("Pitching Performance Lab")
  tagline                String  @default("Train like a pro.")
  logoData               String? // base64 data URI for the logo image
  primaryColor           String  @default("#166534")
  accentColor            String  @default("#4ade80")
  // Liability waiver — admin-editable full text + version tag. When admins
  // update the text, bump the version so existing signatures force re-sign.
  liabilityWaiverText    String  @default("") @db.Text
  liabilityWaiverVersion String  @default("2026-04-23")

  // Session defaults
  defaultCapacity         Int @default(8)
  sessionDurationMinutes  Int @default(60)
  registrationCutoffHours Int @default(1)
  cancellationCutoffHours Int @default(6)

  // Finance reporting cadence — which day the weekly report window starts,
  // and which day at what time the week "resets" (snapshot is taken, new
  // window begins). ISO-ish: 1 = Monday ... 7 = Sunday (matches JS getDay()
  // after normalizing Sunday=0→7). Defaults to a Mon-Sun week with the
  // reset running Monday at 05:00 local time.
  financeWeekStartDay  Int @default(1) // 1=Mon ... 7=Sun
  financeWeekResetDay  Int @default(1) // day the snapshot is taken
  financeWeekResetHour Int @default(5) // 24h local time

  updatedAt DateTime @updatedAt

  @@map("org_settings")
}

// ============================================================
// CRM — LEADS & SALES PIPELINE (April 2026)
// ============================================================
// Core sales-funnel primitives for the Content & Marketing role + anyone
// shepherding prospects into memberships. Separate from `AthleteProfile`
// on purpose — a Lead is someone we HOPE becomes a member; conversion
// links them to a real User + AthleteProfile via `convertedToUserId`.
//
// Design notes:
//   - Email is UNIQUE so we can dedupe inbound form submissions to the
//     same prospect instead of creating a new Lead every time.
//   - After conversion, the Lead stays around for attribution reporting;
//     we never delete won leads.
//   - `source_json` holds the raw form payload / referrer / ad creative
//     metadata so marketing can analyze which creatives are working
//     without us having to predict every field up front.

model Lead {
  id                String        @id @default(uuid())
  organizationId    String        @default("ppl")
  firstName         String
  lastName          String
  email             String
  phone             String?
  // 'youth' | 'ms_hs' | 'college' | 'pro' — helps route to the right coach
  ageGroup          String?
  source            LeadSource    @default(OTHER)
  stage             PipelineStage @default(NEW)
  locationId        String? // Location they're interested in; nullable
  ownerUserId       String? // Staff shepherding this lead
  convertedToUserId String?       @unique // Links to User after CLOSED_WON
  convertedAt       DateTime?
  lostReason        String? // Why CLOSED_LOST if applicable
  nextFollowUpAt    DateTime? // Used by the CRM inbox to sort by "due"
  notes             String? // Free-form — activity stream carries history
  // Raw source payload (GHL form submission, referrer, UTM params, etc.)
  // so we can analyze which creatives / sources convert best without
  // having to predict every field schema-side.
  sourceMetadata    Json?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  // Relations
  location        Location?      @relation(fields: [locationId], references: [id])
  owner           User?          @relation("LeadOwner", fields: [ownerUserId], references: [id])
  convertedToUser User?          @relation("LeadConverted", fields: [convertedToUserId], references: [id])
  activities      LeadActivity[]

  @@unique([organizationId, email])
  @@index([stage, ownerUserId])
  @@index([source])
  @@index([nextFollowUpAt])
  @@index([organizationId])
  @@map("leads")
}

model LeadActivity {
  id           String           @id @default(uuid())
  leadId       String
  type         LeadActivityType
  // Body of the activity — for NOTE, this is the note text; for
  // EMAIL_SENT, the email body; for CALL, the call summary, etc.
  content      String?
  // Who logged the activity (nullable for system-generated STAGE_CHANGE
  // and ASSIGNED entries).
  authorUserId String?
  // Structured payload for system activities:
  //   STAGE_CHANGE: { from: 'NEW', to: 'CONTACTED' }
  //   ASSIGNED:     { fromUserId: '...', toUserId: '...' }
  //   EMAIL_SENT:   { subject: '...', messageId: '...' }
  metadata     Json?
  createdAt    DateTime         @default(now())

  lead   Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  author User? @relation("LeadActivityAuthor", fields: [authorUserId], references: [id])

  @@index([leadId, createdAt])
  @@map("lead_activities")
}

// ============================================================
// MEDICAL SCREENINGS — Renewed Performance integration (April 2026)
// ============================================================
// Medical screenings are separate from regular PPL training sessions.
// They're run by MEDICAL / MEDICAL_ADMIN users (PTs from Renewed
// Performance — a partner medical practice) and track athlete physical
// readiness + recovery metrics.
//
// Why a separate model from Session/Booking:
//   - Different workflows (PT assessment vs pitching coach training)
//   - Different revenue stream (fees go to Renewed Performance, not PPL)
//   - Different data shape (structured pass/fail metrics vs freeform notes)
//
// Revenue model:
//   Every COMPLETED screening accumulates `providerFeeCents` in what
//   Renewed Performance is owed for that week. The Medical Admin (just
//   Renewed's owner, at this point) sees their weekly take grouped by
//   location via a dedicated endpoint.

model MedicalScreening {
  id               String          @id @default(uuid())
  organizationId   String          @default("ppl")
  athleteId        String
  // Which PT / medical staff is assigned. Nullable so admins can
  // schedule first and assign later.
  providerUserId   String?
  locationId       String
  scheduledAt      DateTime
  status           ScreeningStatus @default(SCHEDULED)
  checkedInAt      DateTime?
  completedAt      DateTime?
  durationMinutes  Int             @default(30)
  // Fee Renewed Performance earns for this screening. Default matches
  // the contract rate; adjust per-screening if needed. Only billed
  // when status hits COMPLETED.
  providerFeeCents Int             @default(7500) // $75 default
  // Notes shared with the athlete's PPL performance coach after the
  // screening — drives cross-functional recommendations. Visible to
  // COORDINATOR / PERFORMANCE_COACH + the athlete's parent.
  shareableNotes   String?
  // Internal clinical notes — only visible to MEDICAL and MEDICAL_ADMIN
  // roles. Kept separate so nothing clinical leaks into the coaching
  // side of the app.
  medicalNotes     String?
  // Did the athlete opt in to marketing from Renewed Performance? Gates
  // whether their email appears in the Medical Admin's exportable list.
  marketingOptIn   Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  athlete  AthleteProfile    @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  provider User?             @relation("ScreeningProvider", fields: [providerUserId], references: [id])
  location Location          @relation(fields: [locationId], references: [id])
  results  ScreeningResult[]

  @@index([providerUserId, scheduledAt])
  @@index([athleteId, scheduledAt])
  @@index([locationId, scheduledAt])
  @@index([status])
  @@index([organizationId])
  @@map("medical_screenings")
}

model ScreeningResult {
  id          String   @id @default(uuid())
  screeningId String
  // What was measured — e.g. "Shoulder ER", "Hip internal rotation",
  // "Single-leg squat depth". Free-form string so PTs can introduce
  // new metrics without schema changes. If we ever want a canonical
  // catalog we can add a ScreeningMetric table later.
  metric      String
  // Numeric value where applicable (degrees of rotation, lbs of force,
  // etc.). Stored as Float for the occasional fractional reading.
  value       Float?
  unit        String? // 'degrees', 'lbs', 'in', 'seconds', etc.
  // For pass/fail metrics (e.g. FMS screen positions). Redundant with
  // `value` but way simpler to query.
  passOrFail  Boolean?
  // Side-specific results — many PT metrics are measured per side.
  side        String? // 'LEFT' | 'RIGHT' | null for bilateral
  notes       String?
  createdAt   DateTime @default(now())

  screening MedicalScreening @relation(fields: [screeningId], references: [id], onDelete: Cascade)

  @@index([screeningId])
  @@map("screening_results")
}
