// ============================================================
// ORGANIZATION SETTINGS (PPL branding & defaults)
// ============================================================

/**
 * EducationalResource — admin-curated content (videos + guides) that
 * clients see on their parent dashboard. Feeds the EducationalContent
 * widget. Intentionally simple: title + short description + optional
 * video URL + optional body markdown + category tag + visibility flag.
 * Visibility:
 * ageGroupFilter — null = all clients; otherwise comma-separated list
 * of age groups ('youth,ms_hs,college,pro'). Lets admins target,
 * e.g. "only show this to Youth parents."
 * isPublished — simple on/off switch for draft vs live content.
 */
/**
 * PasswordResetToken — durable, DB-backed password reset tokens.
 * The raw token is never stored. We store a SHA-256 hash of the token.
 * When a user hits POST /reset-password with a token, we hash the
 * submitted value and look it up. This means a DB read (leak, backup,
 * rogue DBA) can't be used to hijack a live reset link.
 * Cleanup: expired rows are swept by the normal cleanup cron (every
 * 15 min — see cronService). Rows are also deleted on successful use.
 */
model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique // SHA-256 of the raw token bytes
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model EducationalResource {
  id             String   @id @default(uuid())
  organizationId String   @default("ppl")
  title          String
  description    String
  body           String? // optional markdown body for longer articles
  videoUrl       String? // optional Youtube/Vimeo embed URL
  thumbnailUrl   String? // optional card thumbnail image
  category       String   @default("general") // 'onboarding' | 'mechanics' | 'mindset' | 'perks' | 'general'
  ageGroupFilter String? // null = all; else comma-separated age groups
  sortOrder      Int      @default(0)
  isPublished    Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId, isPublished])
  @@map("educational_resources")
}

/**
 * LiabilityWaiverSignature — an immutable record that a specific athlete
 * signed the liability waiver. Stores the FULL waiver text + version that
 * was shown at signing time so the contract is preserved even when admins
 * later update the master waiver copy.
 * One signature per (athleteProfileId, waiverVersion). If we bump the
 * waiver version, existing athletes must re-sign the new version before
 * their next booking.
 */
model LiabilityWaiverSignature {
  id               String   @id @default(uuid())
  athleteProfileId String
  signedByUserId   String // User who actually clicked "sign" (parent for Youth/MS-HS; the athlete for solo College/Pro)
  signedByName     String // Typed signature name
  athleteName      String // Snapshot of athlete's full name
  waiverVersion    String // e.g. '2026-04-23'
  waiverText       String   @db.Text // Full waiver text snapshot
  ipAddress        String?
  userAgent        String?
  signedAt         DateTime @default(now())

  athleteProfile AthleteProfile @relation(fields: [athleteProfileId], references: [id], onDelete: Cascade)
  signedByUser   User           @relation(fields: [signedByUserId], references: [id])

  @@unique([athleteProfileId, waiverVersion])
  @@index([athleteProfileId])
  @@map("liability_waiver_signatures")
}

model OrgSettings {
  id                     String  @id @default("ppl") // singleton row
  businessName           String  @default("Pitching Performance Lab")
  tagline                String  @default("Train like a pro.")
  logoData               String? // base64 data URI for the logo image
  primaryColor           String  @default("#166534")
  accentColor            String  @default("#4ade80")
  // Liability waiver — admin-editable full text + version tag. When admins
  // update the text, bump the version so existing signatures force re-sign.
  liabilityWaiverText    String  @default("") @db.Text
  liabilityWaiverVersion String  @default("2026-04-23")

  // Session defaults
  defaultCapacity         Int @default(8)
  sessionDurationMinutes  Int @default(60)
  registrationCutoffHours Int @default(1)
  cancellationCutoffHours Int @default(6)

  // Finance reporting cadence — which day the weekly report window starts,
  // and which day at what time the week "resets" (snapshot is taken, new
  // window begins). ISO-ish: 1 = Monday ... 7 = Sunday (matches JS getDay()
  // after normalizing Sunday=0→7). Defaults to a Mon-Sun week with the
  // reset running Monday at 05:00 local time.
  financeWeekStartDay  Int @default(1) // 1=Mon ... 7=Sun
  financeWeekResetDay  Int @default(1) // day the snapshot is taken
  financeWeekResetHour Int @default(5) // 24h local time

  // Reputation management — review URLs used by the "Send Review Request"
  // button on each member profile. Admins paste a Google Places writereview
  // link or Facebook page review URL; the request email links there
  // directly so the recipient's tap → review takes one click.
  googleReviewUrl   String?
  facebookReviewUrl String?
  // Google Place ID (used by the review-monitoring cron — Phase 2 #28).
  // Get it from https://developers.google.com/maps/documentation/places/web-service/place-id
  // (e.g. "ChIJyQEs1aH2Lr0BdDw7-iaXfa3O")
  googlePlaceId     String?

  updatedAt DateTime @updatedAt

  @@map("org_settings")
}

// ============================================================
// CRM — LEADS & SALES PIPELINE (April 2026)
// ============================================================
// Core sales-funnel primitives for the Content & Marketing role + anyone
// shepherding prospects into memberships. Separate from `AthleteProfile`
// on purpose — a Lead is someone we HOPE becomes a member; conversion
// links them to a real User + AthleteProfile via `convertedToUserId`.
//
// Design notes:
//   - Email is UNIQUE so we can dedupe inbound form submissions to the
//     same prospect instead of creating a new Lead every time.
//   - After conversion, the Lead stays around for attribution reporting;
//     we never delete won leads.
//   - `source_json` holds the raw form payload / referrer / ad creative
//     metadata so marketing can analyze which creatives are working
//     without us having to predict every field up front.

model Lead {
  id                String        @id @default(uuid())
  organizationId    String        @default("ppl")
  firstName         String
  lastName          String
  email             String
  phone             String?
  // 'youth' | 'ms_hs' | 'college' | 'pro' — helps route to the right coach
  ageGroup          String?
  source            LeadSource    @default(OTHER)
  stage             PipelineStage @default(NEW)
  locationId        String? // Location they're interested in; nullable
  ownerUserId       String? // Staff shepherding this lead
  convertedToUserId String?       @unique // Links to User after CLOSED_WON
  convertedAt       DateTime?
  lostReason        String? // Why CLOSED_LOST if applicable
  nextFollowUpAt    DateTime? // Used by the CRM inbox to sort by "due"
  notes             String? // Free-form — activity stream carries history
  // Raw source payload (GHL form submission, referrer, UTM params, etc.)
  // so we can analyze which creatives / sources convert best without
  // having to predict every field schema-side.
  sourceMetadata    Json?
  // Lead score 0-100 — computed nightly + on stage changes via
  // services/leadScoring.ts. Higher = warmer / more likely to close.
  // Drives CRM kanban sort order and the "Hot Leads" filter.
  score             Int           @default(0)
  scoreUpdatedAt    DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  // Relations
  location        Location?           @relation(fields: [locationId], references: [id])
  owner           User?               @relation("LeadOwner", fields: [ownerUserId], references: [id])
  convertedToUser User?               @relation("LeadConverted", fields: [convertedToUserId], references: [id])
  activities      LeadActivity[]
  campaignSends   CampaignRecipient[] @relation("CampaignLeadRecipient")

  // Tagging + custom fields (Phase 1A + 1B)
  tagAssignments    TagAssignment[]
  customFieldValues CustomFieldValue[] @relation("LeadCustomFields")

  // Consultation calls this lead has booked
  consultationBookings ConsultationBooking[]

  // Marketing form submissions linked back to this lead (#133)
  marketingFormSubmissions MarketingFormSubmission[] @relation("MarketingFormSubmissionLead")

  @@unique([organizationId, email])
  @@index([stage, ownerUserId])
  @@index([source])
  @@index([nextFollowUpAt])
  @@index([organizationId])
  @@map("leads")
}

model LeadActivity {
  id           String           @id @default(uuid())
  leadId       String
  type         LeadActivityType
  // Body of the activity — for NOTE, this is the note text; for
  // EMAIL_SENT, the email body; for CALL, the call summary, etc.
  content      String?
  // Who logged the activity (nullable for system-generated STAGE_CHANGE
  // and ASSIGNED entries).
  authorUserId String?
  // Structured payload for system activities:
  //   STAGE_CHANGE: { from: 'NEW', to: 'CONTACTED' }
  //   ASSIGNED:     { fromUserId: '...', toUserId: '...' }
  //   EMAIL_SENT:   { subject: '...', messageId: '...' }
  metadata     Json?
  createdAt    DateTime         @default(now())

  lead   Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  author User? @relation("LeadActivityAuthor", fields: [authorUserId], references: [id])

  @@index([leadId, createdAt])
  @@map("lead_activities")
}

// ============================================================
// MEDICAL SCREENINGS — Renewed Performance integration (April 2026)
// ============================================================
// Medical screenings are separate from regular PPL training sessions.
// They're run by MEDICAL / MEDICAL_ADMIN users (PTs from Renewed
// Performance — a partner medical practice) and track athlete physical
// readiness + recovery metrics.
//
// Why a separate model from Session/Booking:
//   - Different workflows (PT assessment vs pitching coach training)
//   - Different revenue stream (fees go to Renewed Performance, not PPL)
//   - Different data shape (structured pass/fail metrics vs freeform notes)
//
// Revenue model:
//   Every COMPLETED screening accumulates `providerFeeCents` in what
//   Renewed Performance is owed for that week. The Medical Admin (just
//   Renewed's owner, at this point) sees their weekly take grouped by
//   location via a dedicated endpoint.

model MedicalScreening {
  id               String          @id @default(uuid())
  organizationId   String          @default("ppl")
  athleteId        String
  // Which PT / medical staff is assigned. Nullable so admins can
  // schedule first and assign later.
  providerUserId   String?
  locationId       String
  scheduledAt      DateTime
  status           ScreeningStatus @default(SCHEDULED)
  checkedInAt      DateTime?
  completedAt      DateTime?
  durationMinutes  Int             @default(30)
  // Fee Renewed Performance earns for this screening. Default matches
  // the contract rate; adjust per-screening if needed. Only billed
  // when status hits COMPLETED.
  providerFeeCents Int             @default(7500) // $75 default
  // Notes shared with the athlete's PPL performance coach after the
  // screening — drives cross-functional recommendations. Visible to
  // COORDINATOR / PERFORMANCE_COACH + the athlete's parent.
  shareableNotes   String?
  // Internal clinical notes — only visible to MEDICAL and MEDICAL_ADMIN
  // roles. Kept separate so nothing clinical leaks into the coaching
  // side of the app.
  medicalNotes     String?
  // Did the athlete opt in to marketing from Renewed Performance? Gates
  // whether their email appears in the Medical Admin's exportable list.
  marketingOptIn   Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  athlete  AthleteProfile    @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  provider User?             @relation("ScreeningProvider", fields: [providerUserId], references: [id])
  location Location          @relation(fields: [locationId], references: [id])
  results  ScreeningResult[]

  @@index([providerUserId, scheduledAt])
  @@index([athleteId, scheduledAt])
  @@index([locationId, scheduledAt])
  @@index([status])
  @@index([organizationId])
  @@map("medical_screenings")
}

// ============================================================
// MARKETING EMAIL CAMPAIGNS (April 2026)
// ============================================================
// Bulk email sends managed by the CONTENT_MARKETING / CONTENT_MARKETING_ADMIN
// roles. Ships as a foundation — schema + basic CRUD endpoints. Automation
// (drip sequences) + Resend fan-out worker arrive in follow-up commits.
//
// Design notes:
//   - EmailCampaign is the message template + targeting + stats rollup.
//   - CampaignRecipient is per-recipient state, produced by fan-out when
//     the campaign transitions SCHEDULED → SENDING. Denormalizes email
//     so we preserve history even if the underlying User/Lead is deleted.
//   - Resend message IDs are stored on each recipient so the inbound
//     webhook handler (added later) can flip status to DELIVERED / OPENED
//     / BOUNCED etc. when Resend fires tracking events.

model EmailCampaign {
  id             String           @id @default(uuid())
  organizationId String           @default("ppl")
  name           String // Internal name (never sent)
  subject        String
  fromName       String           @default("Pitching Performance Lab")
  fromAddress    String           @default("info@pitchingperformancelab.com")
  replyToAddress String?
  bodyHtml       String
  bodyText       String?
  type           CampaignType     @default(MARKETING)
  audience       CampaignAudience @default(CUSTOM_SEGMENT)
  // JSON parameters for the audience selector:
  //   LOCATION_MEMBERS → { locationId: '...' }
  //   AGE_GROUP        → { ageGroup: 'ms_hs' }
  //   IMPORTED_LIST    → { emails: ['a@b.com', ...] }
  audienceFilter Json?
  status         CampaignStatus   @default(DRAFT)
  scheduledFor   DateTime?
  sentAt         DateTime?

  // Stats rollup — maintained by the webhook handler as events flow in.
  totalRecipients  Int @default(0)
  sentCount        Int @default(0)
  deliveredCount   Int @default(0)
  openCount        Int @default(0)
  clickCount       Int @default(0)
  bounceCount      Int @default(0)
  unsubscribeCount Int @default(0)

  createdByUserId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  createdBy  User                @relation("CampaignCreator", fields: [createdByUserId], references: [id])
  recipients CampaignRecipient[]

  @@index([status, scheduledFor])
  @@index([createdByUserId])
  @@index([organizationId])
  @@map("email_campaigns")
}

model CampaignRecipient {
  id         String  @id @default(uuid())
  campaignId String
  // Denormalized — survives User/Lead deletion so historical stats stay intact.
  email      String
  fullName   String?
  // At most one of these is set, depending on which source the recipient
  // was pulled from. Nullable so a direct email (e.g. IMPORTED_LIST) has
  // no user/lead linkage.
  userId     String?
  leadId     String?

  status          RecipientStatus @default(PENDING)
  sentAt          DateTime?
  deliveredAt     DateTime?
  openedAt        DateTime?
  clickedAt       DateTime?
  bouncedAt       DateTime?
  bounceReason    String?
  unsubscribedAt  DateTime?
  resendMessageId String?         @unique

  createdAt DateTime @default(now())

  campaign EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user     User?         @relation("CampaignUserRecipient", fields: [userId], references: [id], onDelete: SetNull)
  lead     Lead?         @relation("CampaignLeadRecipient", fields: [leadId], references: [id], onDelete: SetNull)

  @@index([campaignId, status])
  @@index([email])
  @@index([userId])
  @@map("campaign_recipients")
}

model ScreeningResult {
  id          String   @id @default(uuid())
  screeningId String
  // What was measured — e.g. "Shoulder ER", "Hip internal rotation",
  // "Single-leg squat depth". Free-form string so PTs can introduce
  // new metrics without schema changes. If we ever want a canonical
  // catalog we can add a ScreeningMetric table later.
  metric      String
  // Numeric value where applicable (degrees of rotation, lbs of force,
  // etc.). Stored as Float for the occasional fractional reading.
  value       Float?
  unit        String? // 'degrees', 'lbs', 'in', 'seconds', etc.
  // For pass/fail metrics (e.g. FMS screen positions). Redundant with
  // `value` but way simpler to query.
  passOrFail  Boolean?
  // Side-specific results — many PT metrics are measured per side.
  side        String? // 'LEFT' | 'RIGHT' | null for bilateral
  notes       String?
  createdAt   DateTime @default(now())

  screening MedicalScreening @relation(fields: [screeningId], references: [id], onDelete: Cascade)

  @@index([screeningId])
  @@map("screening_results")
}

// ----------------------------------------------------------------------------
// Webhook idempotency log.
//
// Stripe (and other providers) retry webhooks if our endpoint times out, is
// briefly unreachable, or returns a non-2xx. Without a dedup table the same
// event can hit our handler twice and process credit/membership state changes
// twice — that's how we end up with double-revoked credits or duplicate
// Payment rows even though Payment has a unique constraint on stripeInvoiceId.
//
// Pattern: handler INSERTs a row keyed by the provider's event ID at the very
// top. If the insert violates the unique constraint the event has already
// been processed; we ack and exit. Only the first processing actually does
// work.
// ----------------------------------------------------------------------------
model WebhookEvent {
  id          String    @id @default(uuid())
  // Stripe's evt_xxx ID, or any external provider's event identifier.
  externalId  String    @unique
  // Provider name so we can mix Stripe + future providers in one table.
  provider    String    @default("stripe")
  // Event type ("invoice.payment_failed", etc.) for debugging + analytics.
  eventType   String
  // First-seen timestamp.
  receivedAt  DateTime  @default(now())
  // Filled in when the handler completes successfully.
  processedAt DateTime?
  // If a handler failed, we record the error here so on next retry we can
  // see the prior failure rather than blindly skipping.
  error       String?

  @@index([provider, eventType])
  @@map("webhook_events")
}

// ============================================================================
// REVIEW MONITORING — Phase 2 (#28)
// ----------------------------------------------------------------------------
// Cron polls Google Places API daily for new reviews on the org's Place ID
// (set in OrgSettings.googlePlaceId). New reviews land here, alerting the
// admin via email and opening up the AI-draft-reply workflow (#40).
//
// authorReviewId is Google's stable per-author identifier so we can dedupe
// reruns of the cron — each (organizationId, authorReviewId) pair maps to
// exactly one Review row.
// ============================================================================

model Review {
  id              String   @id @default(uuid())
  organizationId  String   @default("ppl")
  // Provider — currently always "google" but future-proofs for Yelp / FB
  provider        String   @default("google")
  // Stable per-review identifier from the provider
  externalId      String
  authorName      String
  authorPhotoUrl  String?
  rating          Int      // 1-5
  text            String?  @db.Text
  // Original posting time as reported by the provider
  publishedAt     DateTime
  // Where the review can be read (deep link)
  url             String?
  // Owner's published reply (if any). We store both what we drafted and
  // what was actually posted on Google; admin can edit before posting.
  draftReply      String?  @db.Text
  publishedReply  String?  @db.Text
  publishedReplyAt DateTime?
  // First-seen + last-modified locally
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([organizationId, provider, externalId])
  @@index([rating, publishedAt])
  @@map("reviews")
}

// ============================================================================
// CONSULTATION CALENDAR — Phase 2 (#20)
// ----------------------------------------------------------------------------
// Free 15-minute discovery calls that prospects can self-book on a public
// page. Admins create available slots in bulk; the public page lists
// AVAILABLE ones; booking transitions the slot to BOOKED and creates both
// a Lead (or upserts onto an existing one) and a ConsultationBooking.
//
// Why a dedicated model instead of reusing Session: prospects aren't
// members yet, sessions require an active membership + capacity tracking,
// and these are 1-on-1 by design. Cleaner to keep the funnel-side
// scheduling separate from the training-side scheduling.
// ============================================================================

enum ConsultationSlotStatus {
  AVAILABLE
  BOOKED
  CANCELLED
}

model ConsultationSlot {
  id              String                 @id @default(uuid())
  organizationId  String                 @default("ppl")
  startTime       DateTime
  durationMinutes Int                    @default(15)
  // Who'll be on the call. Optional so admin can bulk-create slots and
  // assign hosts later.
  hostUserId      String?
  // Optional location — phone calls are most common for consults but a
  // walkthrough at PPL Lex is also a thing.
  locationId      String?
  status          ConsultationSlotStatus @default(AVAILABLE)
  // Free-form admin note shown alongside the slot in admin UI only.
  internalNote    String?
  createdAt       DateTime               @default(now())

  host     User?                  @relation("ConsultationHost", fields: [hostUserId], references: [id])
  location Location?              @relation(fields: [locationId], references: [id])
  booking  ConsultationBooking?

  @@unique([startTime, hostUserId])
  @@index([status, startTime])
  @@index([organizationId])
  @@map("consultation_slots")
}

model ConsultationBooking {
  id        String   @id @default(uuid())
  slotId    String   @unique
  leadId    String?
  // Snapshotted prospect info — survives even if lead is later deleted.
  name      String
  email     String
  phone     String?
  notes     String?
  createdAt DateTime @default(now())
  cancelledAt DateTime?

  slot ConsultationSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  lead Lead?            @relation(fields: [leadId], references: [id])

  @@index([leadId])
  @@map("consultation_bookings")
}

// ============================================================================
// OUTBOUND WEBHOOKS — Phase 2 (#43)
// ----------------------------------------------------------------------------
// Admin-configured outbound webhooks that fire when system events happen
// (booking created, lead stage changed, payment failed, etc.). Lets Chad
// integrate PPL with external systems (Zapier, Make.com, custom backends)
// without writing a workflow each time.
//
// Each delivery is signed with HMAC-SHA256 using the webhook's `secret`
// field; receivers should verify the X-PPL-Signature header before trusting
// the body. Failed deliveries log to WebhookDelivery for retry + audit.
// ============================================================================

model Webhook {
  id             String   @id @default(uuid())
  organizationId String   @default("ppl")
  // Friendly admin name ("Zapier — new lead → Slack").
  name           String
  // Destination URL.
  url            String
  // Shared secret — receiver computes HMAC and compares to X-PPL-Signature.
  // Auto-generated on create unless admin overrides.
  secret         String
  // Events to subscribe to. Stored as text[] of WorkflowTrigger names so we
  // can reuse the same trigger taxonomy as the workflow engine.
  events         String[]
  isActive       Boolean  @default(true)
  // Last successful delivery — useful for "is this still working?" admin glance.
  lastSuccessAt  DateTime?
  // Track consecutive failures so we can auto-disable noisy dead webhooks.
  consecutiveFailures Int @default(0)
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  createdBy  User?              @relation("WebhookCreatedBy", fields: [createdById], references: [id])
  deliveries WebhookDelivery[]

  @@index([organizationId, isActive])
  @@map("webhooks")
}

model WebhookDelivery {
  id           String   @id @default(uuid())
  webhookId    String
  event        String   // WorkflowTrigger name
  payload      Json
  // HTTP status from the receiver. Null if request failed entirely (DNS, timeout).
  statusCode   Int?
  // Response body (truncated) for debugging.
  responseBody String?  @db.Text
  // Error if the request couldn't even be sent.
  error        String?
  attemptedAt  DateTime @default(now())

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId, attemptedAt])
  @@map("webhook_deliveries")
}

// ============================================================================
// PHASE 1A — TAGGING SYSTEM
// ----------------------------------------------------------------------------
// Reusable tags that can be attached to Leads, Users, or AthleteProfiles.
// Used for: audience segmentation in marketing campaigns, filtering on
// dashboards, scoping workflow triggers, and quick visual context in lists.
//
// Built-in tags are seeded on bootstrap (one per location, one per playing
// level, one per high-level lifecycle status) and marked `system: true` so
// admins can recolor but can't delete them. Anything else is custom.
//
// Polymorphic assignment: a single TagAssignment row points at exactly ONE
// of leadId/userId/athleteProfileId. We avoid a single Subject join table
// because that would force every consumer to JOIN through it — direct FK
// columns keep query plans readable and let Postgres enforce ON DELETE.
// ============================================================================

enum TagKind {
  LOCATION // PPL Lexington, PPL Louisville
  PLAYING_LEVEL // Youth, MS, HS, College, Pro
  LIFECYCLE // Lead, Trial, Active Member, Churned
  CUSTOM // Anything Chad creates
}

model Tag {
  id             String   @id @default(uuid())
  organizationId String   @default("ppl")
  name           String
  // Hex color for the chip. Defaults to PPL green so a fresh tag still
  // looks on-brand.
  color          String   @default("#95C83C")
  kind           TagKind  @default(CUSTOM)
  // System tags can't be deleted (admins get a 400 if they try).
  system         Boolean  @default(false)
  // Optional human-readable description for the tag-management page.
  description    String?
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  createdBy   User?           @relation("TagCreatedBy", fields: [createdById], references: [id])
  assignments TagAssignment[]

  @@unique([organizationId, name])
  @@index([organizationId, kind])
  @@map("tags")
}

model TagAssignment {
  id               String    @id @default(uuid())
  tagId            String
  // Exactly ONE of these three is non-null.
  leadId           String?
  userId           String?
  athleteProfileId String?
  // Who attached the tag (null for system / workflow-driven assignments).
  assignedById     String?
  // Optional auto-expire — used by lifecycle tags ("Trial" auto-expires
  // when the trial period ends) and short-term campaign tags.
  expiresAt        DateTime?
  createdAt        DateTime  @default(now())

  tag            Tag             @relation(fields: [tagId], references: [id], onDelete: Cascade)
  lead           Lead?           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user           User?           @relation("UserTags", fields: [userId], references: [id], onDelete: Cascade)
  athleteProfile AthleteProfile? @relation("AthleteTags", fields: [athleteProfileId], references: [id], onDelete: Cascade)
  assignedBy     User?           @relation("TagAssignedBy", fields: [assignedById], references: [id])

  // Prevent duplicate (tag, subject) pairs.
  @@unique([tagId, leadId])
  @@unique([tagId, userId])
  @@unique([tagId, athleteProfileId])
  @@index([leadId])
  @@index([userId])
  @@index([athleteProfileId])
  @@index([tagId])
  @@map("tag_assignments")
}

// ============================================================================
// PHASE 1B — CUSTOM FIELDS
// ----------------------------------------------------------------------------
// Per-organization custom fields that can be attached to Lead, User, or
// AthleteProfile. Used for things like "throws hand", "dominant pitch",
// "school", "current velo" — info the team wants to track but that doesn't
// merit a dedicated schema column yet.
//
// Field values are stored as strings; the field type drives parsing and
// validation. SELECT and MULTI_SELECT options live in the definition's
// `options` JSON.
// ============================================================================

enum CustomFieldEntity {
  LEAD
  USER
  ATHLETE_PROFILE
}

enum CustomFieldType {
  TEXT
  LONG_TEXT
  NUMBER
  DATE
  BOOLEAN
  SELECT
  MULTI_SELECT
  EMAIL
  URL
  PHONE
}

model CustomFieldDefinition {
  id             String            @id @default(uuid())
  organizationId String            @default("ppl")
  entityType     CustomFieldEntity
  name           String
  // URL-safe identifier — auto-derived from `name` on create.
  slug           String
  fieldType      CustomFieldType
  // For SELECT / MULTI_SELECT: { options: ["A","B","C"] }
  // For NUMBER: { min, max, step, unit }
  // For TEXT: { placeholder, maxLength }
  config         Json?
  required       Boolean           @default(false)
  // Display order in forms. Smaller = earlier.
  order          Int               @default(0)
  // If false, the field is hidden in pickers + forms but its existing
  // values are preserved. Lets admins retire a field without losing data.
  active         Boolean           @default(true)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  values CustomFieldValue[]

  @@unique([organizationId, entityType, slug])
  @@index([organizationId, entityType, order])
  @@map("custom_field_definitions")
}

model CustomFieldValue {
  id               String   @id @default(uuid())
  fieldId          String
  // Polymorphic — ONE of these is non-null. We could enforce via partial
  // unique indexes; the route layer also enforces.
  leadId           String?
  userId           String?
  athleteProfileId String?
  // Stored as string; consumers parse based on the field's fieldType.
  // For MULTI_SELECT this is JSON-encoded array.
  value            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  field          CustomFieldDefinition @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  lead           Lead?                 @relation("LeadCustomFields", fields: [leadId], references: [id], onDelete: Cascade)
  user           User?                 @relation("UserCustomFields", fields: [userId], references: [id], onDelete: Cascade)
  athleteProfile AthleteProfile?       @relation("AthleteCustomFields", fields: [athleteProfileId], references: [id], onDelete: Cascade)

  @@unique([fieldId, leadId])
  @@unique([fieldId, userId])
  @@unique([fieldId, athleteProfileId])
  @@index([leadId])
  @@index([userId])
  @@index([athleteProfileId])
  @@map("custom_field_values")
}

// ============================================================================
// PHASE 1C — WORKFLOW ENGINE
// ----------------------------------------------------------------------------
// Visual-builder-style automations. A Workflow has a Trigger that fires
// when a system event happens (booking created, lead stage changed,
// payment failed, member's birthday, etc.) and a chain of Steps that run
// in order. Steps can: send email, send SMS, send in-app notification,
// add/remove tags, update fields, wait, branch, or fire a webhook.
//
// When a trigger fires we create a WorkflowRun row, run synchronous steps
// inline, and persist between WAIT steps so the worker can resume them.
// Run state lets us debug, replay, and audit every automation execution.
//
// This commit ships the schema + sync executor only — the time-delayed
// worker is the next commit.
// ============================================================================

enum WorkflowTrigger {
  // Booking lifecycle
  BOOKING_CREATED
  BOOKING_CANCELLED
  BOOKING_COMPLETED
  BOOKING_NO_SHOW
  // Lead lifecycle
  LEAD_CREATED
  LEAD_STAGE_CHANGED
  LEAD_FORM_SUBMITTED
  // User / member lifecycle
  USER_REGISTERED
  MEMBER_PAYMENT_FAILED
  MEMBER_PAYMENT_SUCCEEDED
  MEMBER_BIRTHDAY
  MEMBER_TRIAL_ENDING
  MEMBER_CHURNED
  // Manual trigger from UI ("Send to this lead now")
  MANUAL
  // Cron-style — fires on a schedule
  SCHEDULED
}

enum WorkflowStepType {
  WAIT // pauses for N hours/days
  SEND_EMAIL // template + audience = subject row
  SEND_SMS // body templated
  SEND_NOTIFICATION // in-app push
  ADD_TAG
  REMOVE_TAG
  UPDATE_LEAD_STAGE
  UPDATE_LEAD_FIELD
  ASSIGN_OWNER
  SEND_WEBHOOK
  BRANCH // condition → continue with one of two next steps
  END // explicit termination
}

enum WorkflowRunStatus {
  PENDING // queued, hasn't started
  RUNNING // mid-flight
  WAITING // paused at a WAIT step until resumeAt
  COMPLETED
  FAILED
  CANCELLED
}

model Workflow {
  id             String          @id @default(uuid())
  organizationId String          @default("ppl")
  name           String
  description    String?
  trigger        WorkflowTrigger
  // Trigger-specific filter config. Examples:
  //   BOOKING_CREATED: { sessionType?: 'PITCHING_ASSESSMENT', locationId?: '...' }
  //   LEAD_STAGE_CHANGED: { fromStage?: 'NEW', toStage: 'TRIAL_SCHEDULED' }
  //   SCHEDULED: { cron: '0 9 * * *', timezone: 'America/New_York' }
  triggerConfig  Json?
  isActive       Boolean         @default(true)
  // Optional creator metadata.
  createdById    String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  createdBy User?          @relation("WorkflowCreatedBy", fields: [createdById], references: [id])
  steps     WorkflowStep[]
  runs      WorkflowRun[]

  @@index([organizationId, trigger, isActive])
  @@map("workflows")
}

model WorkflowStep {
  id           String           @id @default(uuid())
  workflowId   String
  // 1-indexed display order. Step execution actually follows the
  // `nextStepId` graph below; order is just for the visual builder.
  displayOrder Int              @default(0)
  type         WorkflowStepType
  // Step-specific config. Examples:
  //   SEND_EMAIL: { templateId?: 'invite_v2', subject: '...', body: '...' }
  //   WAIT:       { hours: 24 }  or  { days: 7 }
  //   ADD_TAG:    { tagId: '...' }
  //   BRANCH:     { conditionField: 'lead.stage', operator: 'eq', value: 'TRIAL_COMPLETED', trueNextStepId, falseNextStepId }
  //   SEND_WEBHOOK: { url: 'https://...', method: 'POST', headers: {...} }
  config       Json
  // The step that runs after this one completes. NULL means "end run."
  // For BRANCH, set to NULL and use config.trueNextStepId / falseNextStepId.
  nextStepId   String?

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId, displayOrder])
  @@map("workflow_steps")
}

model WorkflowRun {
  id            String            @id @default(uuid())
  workflowId    String
  // What triggered this run — used to populate template variables and
  // to filter "show me all runs for this lead".
  contextType   String // 'lead' | 'user' | 'booking' | 'athlete'
  contextId     String
  status        WorkflowRunStatus @default(PENDING)
  currentStepId String?
  // For WAITING runs: when the worker should resume this run.
  resumeAt      DateTime?
  startedAt     DateTime          @default(now())
  completedAt   DateTime?
  // Step-by-step audit trail so we can replay + debug. Each entry:
  //   { stepId, type, startedAt, completedAt, ok, output?, error? }
  log           Json?
  // If status=FAILED, the message that broke us.
  error         String?

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId, status])
  @@index([status, resumeAt])
  @@index([contextType, contextId])
  @@map("workflow_runs")
}
