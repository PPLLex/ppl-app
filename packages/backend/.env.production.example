# =============================================================================
# PPL Backend — Production Environment Variables
# Copy this to .env and fill in your real values
# =============================================================================

# ---- Database (Supabase) ----
# Go to: Supabase Dashboard > Project > Settings > Database > Connection string
# Use the "URI" format, swap [YOUR-PASSWORD] with your DB password
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection for migrations (bypasses pgbouncer)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# ---- JWT ----
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET="CHANGE_ME_generate_a_64_char_random_string"
JWT_EXPIRES_IN="7d"

# ---- Stripe ----
# Dashboard: https://dashboard.stripe.com/apikeys (use LIVE keys for production)
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ---- Twilio (SMS) ----
# Dashboard: https://console.twilio.com
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="..."
TWILIO_PHONE_NUMBER="+18175550000"

# ---- Email (SMTP) ----
# Option A: Gmail App Password (Settings > Security > 2FA > App Passwords)
# Option B: SendGrid (smtp.sendgrid.net, port 587, user "apikey", pass = API key)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="cmart@pitchingperformancelab.com"
SMTP_PASS="your-gmail-app-password"
SMTP_FROM="\"Pitching Performance Lab\" <noreply@pitchingperformancelab.com>"

# ---- App ----
PORT=4000
NODE_ENV="production"
FRONTEND_URL="https://app.pitchingperformancelab.com"
