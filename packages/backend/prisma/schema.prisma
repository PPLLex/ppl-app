generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  ADMIN
  STAFF
  CLIENT
}

enum SessionType {
  COLLEGE_PITCHING
  MS_HS_PITCHING
  YOUTH_PITCHING
  PRIVATE_LESSON
  CAGE_RENTAL
}

enum BookingStatus {
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum MembershipStatus {
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED
}

enum BillingDay {
  MONDAY
  THURSDAY
}

enum LocationRole {
  OWNER // Full revenue, settings, manage staff at this location
  PITCHING_COORDINATOR // Regular pitching coordinator — revenue splits, member data
  YOUTH_COORDINATOR // Youth pitching coordinator — revenue splits, member data
  COACH // See schedule and their own assigned clients only
  TRAINER // General trainer — similar to coach
}

// --- Family & Onboarding enums ---

enum AccountType {
  INDIVIDUAL // Single athlete, self-managed
  FAMILY // Parent managing 1+ athlete children
  PARTNER_SCHOOL // School team — lump-sum billing, no individual payments
}

enum AthleteRelationType {
  SELF // College athlete managing their own account
  CHILD // Parent's child
  TEAM_MEMBER // Part of a partner school team
}

enum OnboardingStatus {
  NEW // First time at PPL — owes $300 onboarding fee
  RETURNING // Has trained before — no fee
  PARTNER_SCHOOL // School athlete — no fee
}

enum OnboardingFeeStatus {
  REQUIRED // Fee owed, not yet paid
  PROCESSING // Stripe checkout in progress
  PAID // Fee collected
  WAIVED // Manually waived by admin
  NOT_APPLICABLE // Returning athlete or partner school — no fee
}

enum TrainingDeliveryPreference {
  IN_PERSON
  REMOTE
  HYBRID
}

enum SchoolInvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  VOID
}

enum CoachInviteStatus {
  NOT_SENT
  SENT
  ACCEPTED // Coach opened the link and submitted roster
  EXPIRED
}

enum ContractStatus {
  DRAFT
  SENT
  SIGNED
  EXPIRED
  VOIDED
}

enum SchoolCoachRole {
  HEAD_COACH
  ASSISTANT_COACH
  DIRECTOR
}

enum MetricType {
  FASTBALL_VELO
  CHANGEUP_VELO
  CURVEBALL_VELO
  SLIDER_VELO
  CUTTER_VELO
  SPIN_RATE
  COMMAND_SCORE
  MECHANICAL_SCORE
  BODY_WEIGHT
  CUSTOM
}

enum PaymentStatus {
  SUCCEEDED
  FAILED
  RETRYING
  REFUNDED
}

enum CardChangeRequestStatus {
  PENDING
  LINK_SENT
  COMPLETED
  DENIED
}

enum NotificationType {
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  BOOKING_REMINDER
  PAYMENT_SUCCEEDED
  PAYMENT_FAILED
  CREDITS_REVOKED
  CREDITS_RESTORED
  NEW_MESSAGE
  SCHEDULE_CHANGED
  MEMBERSHIP_STATUS_CHANGE
}

enum NotificationChannel {
  EMAIL
  SMS
  PUSH
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

// ============================================================
// ORGANIZATIONS — top-level tenant layer
// ============================================================
// Every business entity lives under an Organization. PPL is the first org,
// HPL and Renewed Performance come online as separate brands. Apps share
// the same backend + DB; each app reads org context from its domain or the
// user's memberships and filters all queries by organizationId. See
// ARCHITECTURE.md at the repo root for the rules and phases.
//
// The four seeded orgs use their slugs as primary keys (not UUIDs) so code
// and SQL can reference them readably:
//   - "ppl"                  Pitching Performance Lab
//   - "hpl"                  Hitting Performance Lab
//   - "hpl-youth"            HPL Youth (sub-brand, may consolidate into hpl)
//   - "renewed-performance"  Renewed Performance (screenings, no client memberships)

model Organization {
  id        String  @id // slug used as ID: "ppl", "hpl", ...
  name      String // "Pitching Performance Lab"
  shortName String // "PPL"
  tagline   String?

  // Branding
  logoUrl      String?
  logoData     String? // base64 fallback
  primaryColor String  @default("#5E9E50")
  accentColor  String  @default("#95C83C")

  // Domain routing — used by the frontend OrgContext to pick the active org
  primaryDomain     String?  @unique // e.g., "app.pitchingperformancelab.com"
  additionalDomains String[] @default([])

  // Stripe — charges for this org's memberships land on this account.
  // Joint memberships are charged once on the originating app's Stripe account
  // and reconciled via the revenue ledger (see services/revenueLedger.ts).
  stripeAccountId String?

  // Defaults used when creating sessions/rooms in this org
  defaultCapacity         Int @default(8)
  sessionDurationMinutes  Int @default(60)
  registrationCutoffHours Int @default(1)
  cancellationCutoffHours Int @default(6)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("organizations")
}

// ============================================================
// LOCATIONS
// ============================================================

model Location {
  id             String   @id @default(uuid())
  name           String
  address        String?
  phone          String?
  timezone       String   @default("America/Chicago")
  operatingHours Json? // { monday: { open: "06:00", close: "21:00" }, ... }
  closedDay      String? // e.g., "sunday"
  kioskPin       String? // 4-6 digit PIN for self-service kiosk check-in
  // See ARCHITECTURE.md — every org-tagged table defaults to "ppl" so existing
  // rows land on PPL when the column is added, and Organization FK is added
  // in a follow-up migration once the 4 orgs are seeded.
  organizationId String   @default("ppl")
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  users                User[]
  staffLocations       StaffLocation[]
  rooms                Room[]
  sessions             Session[]
  clientMemberships    ClientMembership[]
  conversations        Conversation[]
  auditLogs            AuditLog[]
  families             Family[]
  schoolTeams          SchoolTeam[]
  scheduleTemplates    ScheduleTemplate[]
  sessionTypeConfigs   SessionTypeConfig[]
  attendanceViolations AttendanceViolation[]

  @@index([organizationId])
  @@map("locations")
}

// ============================================================
// USERS & AUTH
// ============================================================

model User {
  id               String  @id @default(uuid())
  email            String  @unique
  passwordHash     String? // Optional — null for OAuth-only accounts
  fullName         String
  phone            String?
  role             Role    @default(CLIENT)
  homeLocationId   String?
  isActive         Boolean @default(true)
  stripeCustomerId String? @unique

  // Family & account type fields
  accountType  AccountType @default(INDIVIDUAL)
  isParent     Boolean     @default(false)
  parentUserId String? // Self-ref: college athletes who opt out of adding a parent

  // OAuth fields
  authProvider String? // "email", "google", "apple" — primary auth method
  googleId     String? @unique
  appleId      String? @unique
  avatarUrl    String?

  // Magic link fields
  magicLinkToken  String?   @unique
  magicLinkExpiry DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  homeLocation       Location?           @relation(fields: [homeLocationId], references: [id])
  parentUser         User?               @relation("ParentChild", fields: [parentUserId], references: [id])
  childUsers         User[]              @relation("ParentChild")
  clientProfile      ClientProfile?
  family             Family?             @relation("FamilyParent")
  athleteProfile     AthleteProfile?     @relation("AthleteUser")
  staffLocations     StaffLocation[]
  coachedSessions    Session[]           @relation("SessionCoach")
  bookings           Booking[]
  clientMemberships  ClientMembership[]
  weeklyCredits      WeeklyCredit[]
  payments           Payment[]
  cardChangeRequests CardChangeRequest[] @relation("ClientCardRequests")
  adminCardRequests  CardChangeRequest[] @relation("AdminCardRequests")
  sentMessages       Message[]
  notifications      Notification[]
  pushTokens         PushToken[]
  auditLogs          AuditLog[]

  // Coach Notes relations
  athleteNotes     CoachNote[]       @relation("AthleteNotes")
  coachNotes       CoachNote[]       @relation("CoachNotes")
  athleteDigests   NoteDigest[]      @relation("AthleteDigests")
  digestRecipients DigestRecipient[] @relation("DigestRecipients")

  // Goals & Forms relations
  athleteGoals  Goal[]         @relation("AthleteGoals")
  coachGoals    Goal[]         @relation("CoachGoals")
  createdForms  FormTemplate[] @relation("CreatedForms")
  formResponses FormResponse[] @relation("FormResponses")

  // Programming relations
  coachPrograms   Program[] @relation("CoachPrograms")
  athletePrograms Program[] @relation("AthletePrograms")

  // Metrics relations
  athleteMetrics    AthleteMetric[] @relation("AthleteMetrics")
  staffCoachMetrics AthleteMetric[] @relation("StaffCoachMetrics")

  // Schedule template & violation relations
  scheduleTemplates    ScheduleTemplate[]    @relation("TemplateCoach")
  attendanceViolations AttendanceViolation[] @relation("ViolationClient")
  assessedViolations   AttendanceViolation[] @relation("ViolationAssessor")

  @@index([homeLocationId])
  @@index([role])
  @@index([email])
  @@map("users")
}

model ClientProfile {
  id                    String                      @id @default(uuid())
  userId                String                      @unique
  ageGroup              String? // "youth", "ms_hs", "college"
  dateOfBirth           DateTime?
  emergencyContactName  String?
  emergencyContactPhone String?
  trainingGoals         String?
  trainingPreference    TrainingDeliveryPreference?
  notes                 String?
  waiverSignedAt        DateTime?
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("client_profiles")
}

model StaffLocation {
  id         String         @id @default(uuid())
  staffId    String
  locationId String
  roles      LocationRole[] @default([COACH])
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  // Relations
  staff    User     @relation(fields: [staffId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([staffId, locationId])
  @@index([locationId])
  @@map("staff_locations")
}

model StaffInvite {
  id        String    @id @default(uuid())
  email     String
  fullName  String
  phone     String?
  token     String    @unique @default(uuid())
  role      Role      @default(STAFF)
  locations Json // [{locationId, roles: ['PITCHING_COORDINATOR', ...]}]
  expiresAt DateTime
  usedAt    DateTime?
  invitedBy String?
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([email])
  @@map("staff_invites")
}

// ============================================================
// ROOMS & SCHEDULING
// ============================================================

model Room {
  id         String   @id @default(uuid())
  locationId String
  name       String
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  location          Location           @relation(fields: [locationId], references: [id], onDelete: Cascade)
  sessions          Session[]
  scheduleTemplates ScheduleTemplate[]

  @@index([locationId])
  @@map("rooms")
}

model Session {
  id                      String      @id @default(uuid())
  organizationId          String      @default("ppl")
  locationId              String
  roomId                  String?
  coachId                 String?
  title                   String
  sessionType             SessionType
  startTime               DateTime
  endTime                 DateTime
  maxCapacity             Int         @default(8)
  currentEnrolled         Int         @default(0)
  recurringRule           String? // iCal RRULE format
  recurringGroupId        String? // links recurring instances
  registrationCutoffHours Int         @default(2)
  cancellationCutoffHours Int         @default(4)
  isActive                Boolean     @default(true)
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  // Relations
  location             Location              @relation(fields: [locationId], references: [id])
  room                 Room?                 @relation(fields: [roomId], references: [id])
  coach                User?                 @relation("SessionCoach", fields: [coachId], references: [id])
  bookings             Booking[]
  attendanceViolations AttendanceViolation[]

  @@index([organizationId, startTime])
  @@index([locationId, startTime])
  @@index([coachId])
  @@index([sessionType])
  @@index([recurringGroupId])
  @@map("sessions")
}

model Booking {
  id                 String        @id @default(uuid())
  clientId           String
  sessionId          String
  status             BookingStatus @default(CONFIRMED)
  creditsUsed        Int           @default(1)
  cancelledAt        DateTime?
  cancellationReason String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  // Relations
  client             User                @relation(fields: [clientId], references: [id])
  session            Session             @relation(fields: [sessionId], references: [id])
  creditTransactions CreditTransaction[]
  coachNotes         CoachNote[]

  @@unique([clientId, sessionId])
  @@index([clientId, status])
  @@index([sessionId])
  @@map("bookings")
}

// ============================================================
// ATTENDANCE VIOLATIONS & FINES
// ============================================================

enum ViolationType {
  NO_SIGNUP // Showed up without booking ($20 fine)
  WRONG_TIME // Showed up at incorrect session time ($10 fine)
}

enum ViolationStatus {
  PENDING // Fine assessed, not yet paid
  PAID // Fine collected via Stripe
  WAIVED // Admin waived the fine
}

model AttendanceViolation {
  id           String          @id @default(uuid())
  clientId     String
  sessionId    String? // Which session they walked into (null if no specific session)
  locationId   String
  type         ViolationType
  amountCents  Int // 2000 = $20, 1000 = $10
  status       ViolationStatus @default(PENDING)
  notes        String? // Coach/admin notes on what happened
  assessedById String // Staff/admin who logged it
  paidAt       DateTime?
  waivedAt     DateTime?
  waivedById   String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  client     User     @relation("ViolationClient", fields: [clientId], references: [id])
  session    Session? @relation(fields: [sessionId], references: [id])
  location   Location @relation(fields: [locationId], references: [id])
  assessedBy User     @relation("ViolationAssessor", fields: [assessedById], references: [id])

  @@index([clientId])
  @@index([sessionId])
  @@index([status])
  @@map("attendance_violations")
}

/// Admin-defined weekly schedule template.
/// Each entry is "every Monday at 3pm in Room A, College Pitching".
/// A cron job uses these to auto-generate Session rows 2 weeks ahead.
model ScheduleTemplate {
  id                      String      @id @default(uuid())
  organizationId          String      @default("ppl")
  locationId              String
  roomId                  String?
  coachId                 String?
  title                   String
  sessionType             SessionType
  dayOfWeek               Int // 0=Sunday … 6=Saturday
  startHour               Int // 0-23
  startMinute             Int         @default(0)
  durationMinutes         Int         @default(60)
  maxCapacity             Int         @default(8)
  registrationCutoffHours Int         @default(2)
  cancellationCutoffHours Int         @default(4)
  isActive                Boolean     @default(true)
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  location Location @relation(fields: [locationId], references: [id])
  room     Room?    @relation(fields: [roomId], references: [id])
  coach    User?    @relation("TemplateCoach", fields: [coachId], references: [id])

  @@index([organizationId])
  @@index([locationId, dayOfWeek])
  @@map("schedule_templates")
}

// ============================================================
// SESSION TYPE CONFIGURATION  (per-location defaults per type)
// ============================================================

model SessionTypeConfig {
  id                      String      @id @default(uuid())
  organizationId          String      @default("ppl")
  locationId              String
  sessionType             SessionType
  label                   String // Display name, e.g. "College Pitching"
  maxCapacity             Int         @default(8)
  durationMinutes         Int         @default(60)
  registrationCutoffHours Int         @default(2)
  cancellationCutoffHours Int         @default(4)
  color                   String? // Hex color for calendar display, e.g. "#10B981"
  isActive                Boolean     @default(true)
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  location Location @relation(fields: [locationId], references: [id])

  @@unique([locationId, sessionType])
  @@index([organizationId])
  @@map("session_type_configs")
}

// ============================================================
// MEMBERSHIPS & BILLING
// ============================================================

model MembershipPlan {
  id              String   @id @default(uuid())
  organizationId  String   @default("ppl")
  name            String // "Unlimited College Pitching", "Youth 1x/Week", etc.
  slug            String   @unique
  ageGroup        String // "college", "ms_hs", "youth"
  sessionsPerWeek Int? // null = unlimited
  priceCents      Int // e.g., 8500 = $85.00
  billingCycle    String   @default("weekly")
  description     String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  clientMemberships ClientMembership[]

  @@index([organizationId])
  @@map("membership_plans")
}

model ClientMembership {
  id                   String           @id @default(uuid())
  clientId             String
  planId               String
  locationId           String
  athleteId            String? // Links to AthleteProfile — null for legacy memberships
  status               MembershipStatus @default(ACTIVE)
  stripeSubscriptionId String?          @unique
  stripePriceId        String?
  billingDay           BillingDay
  billingAnchorDate    DateTime
  startedAt            DateTime         @default(now())
  cancelledAt          DateTime?
  cancelRequestedAt    DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  // Relations
  client        User            @relation(fields: [clientId], references: [id])
  plan          MembershipPlan  @relation(fields: [planId], references: [id])
  location      Location        @relation(fields: [locationId], references: [id])
  athlete       AthleteProfile? @relation(fields: [athleteId], references: [id])
  weeklyCredits WeeklyCredit[]
  payments      Payment[]

  @@index([clientId, status])
  @@index([status])
  @@index([billingDay])
  @@map("client_memberships")
}

model WeeklyCredit {
  id             String   @id @default(uuid())
  // org is direct here because joint memberships split credits into pools
  // tagged per-org (1 PPL credit + 1 HPL credit, never cross-spendable).
  // Filtering credits by org is a hot path.
  organizationId String   @default("ppl")
  clientId       String
  membershipId   String
  creditsTotal   Int
  creditsUsed    Int      @default(0)
  weekStartDate  DateTime
  weekEndDate    DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  client     User             @relation(fields: [clientId], references: [id])
  membership ClientMembership @relation(fields: [membershipId], references: [id])

  @@unique([clientId, membershipId, weekStartDate])
  @@index([clientId, weekStartDate])
  @@index([organizationId, weekStartDate])
  @@map("weekly_credits")
}

model CreditTransaction {
  id              String   @id @default(uuid())
  clientId        String
  transactionType String // "usage", "refund", "revoke", "restore"
  amount          Int // positive = added, negative = used/revoked
  bookingId       String?
  paymentId       String?
  notes           String?
  createdAt       DateTime @default(now())

  // Relations
  booking Booking? @relation(fields: [bookingId], references: [id])

  @@index([clientId, createdAt])
  @@map("credit_transactions")
}

// ============================================================
// PAYMENTS
// ============================================================

model Payment {
  id                    String        @id @default(uuid())
  clientId              String
  membershipId          String?
  stripePaymentIntentId String?       @unique
  stripeInvoiceId       String?       @unique
  amountCents           Int
  status                PaymentStatus
  failureReason         String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  // Relations
  client     User              @relation(fields: [clientId], references: [id])
  membership ClientMembership? @relation(fields: [membershipId], references: [id])

  @@index([clientId, createdAt])
  @@index([status])
  @@map("payments")
}

model CardChangeRequest {
  id               String                  @id @default(uuid())
  clientId         String
  adminId          String?
  status           CardChangeRequestStatus @default(PENDING)
  secureLinkToken  String?                 @unique
  secureLinkExpiry DateTime?
  newCardVerified  Boolean                 @default(false)
  notes            String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  // Relations
  client User  @relation("ClientCardRequests", fields: [clientId], references: [id])
  admin  User? @relation("AdminCardRequests", fields: [adminId], references: [id])

  @@index([clientId])
  @@index([status])
  @@map("card_change_requests")
}

// ============================================================
// MESSAGING
// ============================================================

model Conversation {
  id           String   @id @default(uuid())
  locationId   String?
  participants Json // array of user IDs
  type         String // "client_coach", "client_admin"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  location Location? @relation(fields: [locationId], references: [id])
  messages Message[]

  @@map("conversations")
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  readBy         Json     @default("[]") // array of user IDs who have read
  createdAt      DateTime @default(now())

  // Relations
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id])

  @@index([conversationId, createdAt])
  @@map("messages")
}

// ============================================================
// NOTIFICATIONS
// ============================================================

model Notification {
  id        String              @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  channel   NotificationChannel
  status    NotificationStatus  @default(PENDING)
  metadata  Json? // extra data (booking ID, payment amount, etc.)
  sentAt    DateTime?
  createdAt DateTime            @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([status])
  @@map("notifications")
}

// ============================================================
// PUSH NOTIFICATION TOKENS
// ============================================================

model PushToken {
  id         String   @id @default(uuid())
  userId     String
  token      String   @unique // FCM device token
  deviceInfo String? // "Chrome on Windows", "Safari on iPhone", etc.
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_tokens")
}

// ============================================================
// COACH SESSION NOTES
// ============================================================

enum TrainingCategory {
  PITCHING_MECHANICS
  VELOCITY_TRAINING
  ARM_CARE
  BULLPEN_SESSION
  LIVE_AT_BATS
  VIDEO_REVIEW
  STRENGTH_CONDITIONING
  MENTAL_PERFORMANCE
  GENERAL
  OTHER
}

model CoachNote {
  id               String           @id @default(uuid())
  athleteId        String
  coachId          String? // PPL staff coach (null if school coach)
  schoolCoachId    String? // Partner school coach (null if PPL staff)
  trainingCategory TrainingCategory
  rawContent       String // original note from coach
  cleanedContent   String? // AI-cleaned version (grammar, profanity filtered)
  sessionDate      DateTime         @default(now())
  bookingId        String? // optional link to a specific booking
  isVisible        Boolean          @default(true) // can be hidden if needed
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  // Relations
  athlete     User         @relation("AthleteNotes", fields: [athleteId], references: [id])
  coach       User?        @relation("CoachNotes", fields: [coachId], references: [id])
  schoolCoach SchoolCoach? @relation("SchoolCoachNotes", fields: [schoolCoachId], references: [id])
  booking     Booking?     @relation(fields: [bookingId], references: [id])

  @@index([athleteId, createdAt])
  @@index([coachId, createdAt])
  @@index([schoolCoachId, createdAt])
  @@index([athleteId, trainingCategory])
  @@map("coach_notes")
}

// Weekly email digest tracking
model NoteDigest {
  id          String    @id @default(uuid())
  athleteId   String
  weekStart   DateTime
  weekEnd     DateTime
  emailSentAt DateTime?
  recipients  Json // array of email addresses that received this digest
  noteIds     Json // array of CoachNote IDs included
  htmlContent String? // rendered email content for audit
  createdAt   DateTime  @default(now())

  // Relations
  athlete User @relation("AthleteDigests", fields: [athleteId], references: [id])

  @@unique([athleteId, weekStart])
  @@index([weekStart])
  @@map("note_digests")
}

// Additional email recipients per athlete (parent emails, on-field coaches, etc.)
model DigestRecipient {
  id        String   @id @default(uuid())
  athleteId String
  email     String
  name      String?
  relation  String? // "parent", "coach", "guardian", etc.
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  athlete User @relation("DigestRecipients", fields: [athleteId], references: [id])

  @@unique([athleteId, email])
  @@map("digest_recipients")
}

// ============================================================
// GOALS & GAMIFICATION
// ============================================================

enum GoalType {
  SHORT_TERM // weeks
  LONG_TERM // months/season
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  ABANDONED
}

model Goal {
  id          String     @id @default(uuid())
  athleteId   String
  coachId     String? // coach who set it, or null if self-set
  type        GoalType
  title       String
  description String?
  targetDate  DateTime?
  status      GoalStatus @default(ACTIVE)
  progress    Int        @default(0) // 0-100 percentage
  completedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Relations
  athlete User  @relation("AthleteGoals", fields: [athleteId], references: [id])
  coach   User? @relation("CoachGoals", fields: [coachId], references: [id])

  @@index([athleteId, status])
  @@index([athleteId, type])
  @@map("goals")
}

// ============================================================
// CUSTOM FORMS (onboarding, questionnaires, intake, etc.)
// ============================================================

model FormTemplate {
  id           String   @id @default(uuid())
  createdById  String
  title        String
  description  String?
  fields       Json // array of field definitions: [{name, type, label, required, options}]
  isOnboarding Boolean  @default(false) // if true, new athletes must fill it out
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  createdBy User           @relation("CreatedForms", fields: [createdById], references: [id])
  responses FormResponse[]

  @@map("form_templates")
}

model FormResponse {
  id        String   @id @default(uuid())
  formId    String
  athleteId String
  answers   Json // { fieldName: answer, ... }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  form    FormTemplate @relation(fields: [formId], references: [id])
  athlete User         @relation("FormResponses", fields: [athleteId], references: [id])

  @@unique([formId, athleteId]) // one response per athlete per form (can update)
  @@index([athleteId])
  @@map("form_responses")
}

// ============================================================
// PROGRAMMING / WORKOUT BUILDER
// ============================================================

enum ProgramStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

model Program {
  id          String        @id @default(uuid())
  coachId     String
  athleteId   String
  title       String
  description String?
  status      ProgramStatus @default(DRAFT)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  coach   User          @relation("CoachPrograms", fields: [coachId], references: [id])
  athlete User          @relation("AthletePrograms", fields: [athleteId], references: [id])
  weeks   ProgramWeek[]

  @@index([coachId])
  @@index([athleteId, status])
  @@map("programs")
}

model ProgramWeek {
  id        String   @id @default(uuid())
  programId String
  weekNum   Int
  title     String? // "Week 1 — Foundation", etc.
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  program Program      @relation(fields: [programId], references: [id], onDelete: Cascade)
  days    ProgramDay[]

  @@unique([programId, weekNum])
  @@map("program_weeks")
}

model ProgramDay {
  id        String   @id @default(uuid())
  weekId    String
  dayNum    Int // 1-7
  title     String? // "Monday — Throwing Day"
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  week      ProgramWeek       @relation(fields: [weekId], references: [id], onDelete: Cascade)
  exercises ProgramExercise[]

  @@unique([weekId, dayNum])
  @@map("program_days")
}

model ProgramExercise {
  id          String   @id @default(uuid())
  dayId       String
  sortOrder   Int      @default(0)
  exerciseId  String? // link to exercise library, or null for custom
  customName  String? // if not from library
  sets        Int?
  reps        String? // "10" or "8-12" or "AMRAP"
  intensity   String? // "65%" or "RPE 7" or "Max Effort"
  restSeconds Int?
  tempo       String? // "3-1-1-0"
  notes       String? // coach instructions
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  day      ProgramDay @relation(fields: [dayId], references: [id], onDelete: Cascade)
  exercise Exercise?  @relation(fields: [exerciseId], references: [id])

  @@index([dayId, sortOrder])
  @@map("program_exercises")
}

// Exercise library — reusable exercise definitions
model Exercise {
  id          String   @id @default(uuid())
  name        String
  category    String // "throwing", "arm_care", "strength", "mobility", "conditioning"
  equipment   String? // "plyo_ball", "band", "dumbbell", etc.
  description String?
  videoUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  programExercises ProgramExercise[]

  @@index([category])
  @@map("exercises")
}

// ============================================================
// FAMILIES & ATHLETE PROFILES
// ============================================================

model Family {
  id                String   @id @default(uuid())
  parentUserId      String   @unique // The parent/guardian User
  stripeCustomerId  String?  @unique // One Stripe customer per family
  primaryLocationId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  parent          User             @relation("FamilyParent", fields: [parentUserId], references: [id])
  primaryLocation Location?        @relation(fields: [primaryLocationId], references: [id])
  athletes        AthleteProfile[]

  @@map("families")
}

model AthleteProfile {
  id                   String                      @id @default(uuid())
  userId               String                      @unique // The athlete's own User account
  familyId             String? // null for INDIVIDUAL or PARTNER_SCHOOL
  schoolTeamId         String? // null unless PARTNER_SCHOOL
  relationToParent     AthleteRelationType         @default(SELF)
  firstName            String
  lastName             String
  dateOfBirth          DateTime?
  ageGroup             String? // "youth", "ms_hs", "college", "pro" — SOURCE OF TRUTH for an athlete's playing level. ClientProfile.ageGroup also exists (legacy) but should be treated as a cache; always read from here. Keep them in sync when updating via `$transaction`. See audit issue #11.
  trainingDeliveryPref TrainingDeliveryPreference?
  lastAgeMovedUpAlert  DateTime? // Last time we sent the "move up" notification
  parentOptOut         Boolean                     @default(false) // College athlete opted out of adding parent
  parentOptOutAckedAt  DateTime? // When they acknowledged responsibility
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt

  // Relations
  user             User               @relation("AthleteUser", fields: [userId], references: [id], onDelete: Cascade)
  family           Family?            @relation(fields: [familyId], references: [id])
  schoolTeam       SchoolTeam?        @relation(fields: [schoolTeamId], references: [id])
  onboardingRecord OnboardingRecord?
  memberships      ClientMembership[]

  outsideCoachLinks OutsideCoachLink[]

  @@index([familyId])
  @@index([schoolTeamId])
  @@index([ageGroup])
  @@map("athlete_profiles")
}

// ============================================================
// OUTSIDE COACH LINKS
// ============================================================

/**
 * Links an athlete to their non-PPL coaches (high school, travel ball, etc.)
 * Outside coaches get read-only access to: metrics, reports, and coach notes.
 * They CANNOT book, edit, or see scheduling info — just performance data.
 */
model OutsideCoachLink {
  id           String    @id @default(uuid())
  athleteId    String
  coachName    String // Full name of the outside coach
  coachEmail   String // Email for reports / login
  coachPhone   String?
  organization String? // "Central High School", "Louisville Sluggers Travel", etc.
  coachRole    String? // "Head Coach", "Pitching Coach", "Travel Coach", etc.
  isActive     Boolean   @default(true)
  invitedAt    DateTime  @default(now())
  acceptedAt   DateTime? // When the coach claimed their account
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  athlete AthleteProfile @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  @@unique([athleteId, coachEmail])
  @@index([coachEmail])
  @@map("outside_coach_links")
}

model OnboardingRecord {
  id                 String              @id @default(uuid())
  // Which org's onboarding fee was paid — matters because Renewed Performance
  // will be paid per-athlete by whichever org onboarded them.
  organizationId     String              @default("ppl")
  athleteId          String              @unique
  onboardingStatus   OnboardingStatus    @default(NEW)
  feeStatus          OnboardingFeeStatus @default(REQUIRED)
  onboardingFeeCents Int                 @default(30000) // $300.00
  stripePaymentId    String? // Stripe PI for the onboarding fee
  stripeCheckoutId   String? // Stripe Checkout Session ID
  isYouthGraduate    Boolean             @default(false) // Graduated from PPL Youth → still NEW but gets special messaging
  hadFreeAssessment  Boolean             @default(false) // Did a free assessment but never trained
  qualifyingAnswers  Json? // { "trainedBefore": false, "lastTrainedDate": null, ... }
  selfReportedStatus String? // What the athlete selected: "new", "returning", "youth_graduate", "free_assessment"
  completedAt        DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  // Relations
  athlete AthleteProfile @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("onboarding_records")
}

// ============================================================
// PARTNER SCHOOL TEAMS
// ============================================================

model SchoolTeam {
  id                String  @id @default(uuid())
  name              String // "Lexington Catholic Baseball"
  slug              String  @unique // "lexington-catholic" — used in signup URL
  primaryLocationId String?
  brandLogoUrl      String? // Uploaded school logo
  brandColors       Json? // { primary: "#1a3e72", secondary: "#c4a34d" }
  signupUrl         String? @unique // Generated: /join/team/lexington-catholic

  // Coach info
  coachName         String?
  coachEmail        String?
  coachPhone        String?
  coachInviteToken  String?           @unique // Unique token for coach roster form link
  coachInviteStatus CoachInviteStatus @default(NOT_SENT)
  coachInviteSentAt DateTime?
  rosterSubmittedAt DateTime? // When coach finished submitting the roster

  // Billing contact (may differ from coach)
  paymentContactName  String?
  paymentContactEmail String?
  totalAnnualBudget   Int? // cents — total the school pays
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  primaryLocation Location?        @relation(fields: [primaryLocationId], references: [id])
  athletes        AthleteProfile[]
  invoices        SchoolInvoice[]
  contracts       SchoolContract[]
  coaches         SchoolCoach[]

  @@index([slug])
  @@index([coachInviteToken])
  @@map("school_teams")
}

model SchoolInvoice {
  id              String              @id @default(uuid())
  schoolTeamId    String
  stripeInvoiceId String?             @unique
  description     String? // "Fall 2026 Remote Programming — 25 athletes"
  totalCents      Int
  paidCents       Int                 @default(0)
  status          SchoolInvoiceStatus @default(DRAFT)
  dueDate         DateTime?
  sentAt          DateTime?
  paidAt          DateTime?
  periodStart     DateTime?
  periodEnd       DateTime?
  notes           String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  // Relations
  schoolTeam SchoolTeam @relation(fields: [schoolTeamId], references: [id])

  @@index([schoolTeamId, status])
  @@map("school_invoices")
}

model SchoolContract {
  id              String         @id @default(uuid())
  schoolTeamId    String
  title           String // "PPL Remote Training Agreement — Fall 2026"
  terms           String // Full contract text / terms
  startDate       DateTime
  endDate         DateTime
  totalValueCents Int? // Total contract value
  status          ContractStatus @default(DRAFT)
  signatureToken  String?        @unique // Token for the signing link
  signedByName    String? // Name of person who signed
  signedByEmail   String?
  signedAt        DateTime?
  sentAt          DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Relations
  schoolTeam SchoolTeam @relation(fields: [schoolTeamId], references: [id])

  @@index([schoolTeamId])
  @@index([signatureToken])
  @@map("school_contracts")
}

// ============================================================
// PARTNER SCHOOL COACHES (Login accounts for school coaches)
// ============================================================

model SchoolCoach {
  id           String          @id @default(uuid())
  schoolTeamId String
  email        String          @unique
  passwordHash String
  fullName     String
  phone        String?
  role         SchoolCoachRole @default(HEAD_COACH)
  title        String? // "Director of Pitching", "Head Baseball Coach", etc.

  // Access control — admin checks these boxes per coach
  canViewDashboard      Boolean @default(true)
  canTakeNotes          Boolean @default(true)
  canViewPrograms       Boolean @default(true)
  canViewGoals          Boolean @default(true)
  canViewMetrics        Boolean @default(true)
  canMessageAthletes    Boolean @default(false)
  receivesWeeklySummary Boolean @default(true)

  // Push notification subscription (for PWA)
  pushSubscription Json? // Web Push subscription object
  notifyReminders  Boolean @default(true)

  lastLoginAt DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  schoolTeam     SchoolTeam      @relation(fields: [schoolTeamId], references: [id])
  athleteNotes   CoachNote[]     @relation("SchoolCoachNotes")
  athleteMetrics AthleteMetric[] @relation("SchoolCoachMetrics")

  @@index([schoolTeamId])
  @@index([email])
  @@map("school_coaches")
}

// ============================================================
// ATHLETE METRICS (Velo, spin rate, performance tracking)
// ============================================================

model AthleteMetric {
  id            String     @id @default(uuid())
  athleteId     String
  schoolCoachId String? // null if logged by PPL staff
  staffCoachId  String? // null if logged by school coach
  metricType    MetricType
  value         Float // the measurement value
  unit          String? // "mph", "rpm", "/10", "lbs", etc.
  customLabel   String? // label when metricType is CUSTOM
  sessionDate   DateTime   @default(now())
  notes         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  // Relations
  athlete     User         @relation("AthleteMetrics", fields: [athleteId], references: [id])
  schoolCoach SchoolCoach? @relation("SchoolCoachMetrics", fields: [schoolCoachId], references: [id])
  staffCoach  User?        @relation("StaffCoachMetrics", fields: [staffCoachId], references: [id])

  @@index([athleteId, metricType])
  @@index([athleteId, createdAt])
  @@index([schoolCoachId])
  @@map("athlete_metrics")
}

// ============================================================
// AUDIT
// ============================================================

model AuditLog {
  id           String   @id @default(uuid())
  userId       String?
  locationId   String?
  action       String // "session.created", "session.updated", "booking.cancelled", etc.
  resourceType String // "session", "booking", "membership", etc.
  resourceId   String?
  changes      Json? // { before: {...}, after: {...} }
  ipAddress    String?
  createdAt    DateTime @default(now())

  // Relations
  user     User?     @relation(fields: [userId], references: [id])
  location Location? @relation(fields: [locationId], references: [id])

  @@index([userId])
  @@index([resourceType, resourceId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================================
// ORGANIZATION SETTINGS (PPL branding & defaults)
// ============================================================

model OrgSettings {
  id           String  @id @default("ppl") // singleton row
  businessName String  @default("Pitching Performance Lab")
  tagline      String  @default("Train like a pro.")
  logoData     String? // base64 data URI for the logo image
  primaryColor String  @default("#166534")
  accentColor  String  @default("#4ade80")

  // Session defaults
  defaultCapacity         Int @default(8)
  sessionDurationMinutes  Int @default(60)
  registrationCutoffHours Int @default(1)
  cancellationCutoffHours Int @default(6)

  updatedAt DateTime @updatedAt

  @@map("org_settings")
}
