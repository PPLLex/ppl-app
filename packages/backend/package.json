{
  "name": "@ppl/backend",
  "version": "0.1.0",
  "description": "PPL App Backend — Express + Prisma + TypeScript",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "typecheck": "tsc --noEmit",
    "backfill:rooms": "tsx scripts/backfill-default-rooms.ts",
    "backfill:rooms:dry": "tsx scripts/backfill-default-rooms.ts --dry-run"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
