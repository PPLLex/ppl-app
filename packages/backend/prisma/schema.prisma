  totalCents      Int
  paidCents       Int                 @default(0)
  status          SchoolInvoiceStatus @default(DRAFT)
  dueDate         DateTime?
  sentAt          DateTime?
  paidAt          DateTime?
  periodStart     DateTime?
  periodEnd       DateTime?
  notes           String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  // Relations
